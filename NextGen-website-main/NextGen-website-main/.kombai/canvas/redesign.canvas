data-kid=\"1-5-2-3-4-1\" data-name=\"service explore link arrow\" fill=\"none\" height=\"14\" stroke=\"currentColor\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"14\">\n                        <path d=\"M7 17L17 7M17 7H7M17 7V17\">\n                        </path>\n                    </svg>\n                </a>\n            </div>\n            <!-- Service Card 4 -->\n            <div class=\"group bg-white p-8 md:p-10 rounded-[22px] border border-[#E7E2DA] shadow-[0_20px_60px_-15px_rgba(23,23,23,0.06)] transition-all duration-500 hover:-translate-y-2 hover:border-[#C8A46A]/30 hover:shadow-[0_30px_70px_-15px_rgba(23,23,23,0.1)]\" data-kid=\"1-5-2-4\" data-name=\"service card renovation\">\n                <div class=\"w-12 h-12 mb-10 text-[#C8A46A]\" data-kid=\"1-5-2-4-1\" data-name=\"service card icon container\">\n                    <svg data-kid=\"1-5-2-4-1-1\" data-name=\"renovation icon\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"square\" stroke-width=\"1.2\" viewbox=\"0 0 24 24\">\n                        <path d=\"M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z\">\n                        </path>\n                    </svg>\n                </div>\n                <h3 class=\"font-serif text-2xl md:text-3xl mb-4 group-hover:text-[#C8A46A] transition-colors\" data-kid=\"1-5-2-4-2\" data-name=\"service title renovation\">\n                    Renovation\n                </h3>\n                <p class=\"text-sm text-[#707070] leading-relaxed mb-8\" data-kid=\"1-5-2-4-3\" data-name=\"service description renovation\">\n                    Breathing new life into existing spaces with architectural precision.\n                </p>\n                <a class=\"inline-flex items-center gap-2 text-[11px] tracking-widest uppercase text-[#1E1E1E] font-medium group-hover:text-[#C8A46A] transition-colors\" data-kid=\"1-5-2-4-4\" data-name=\"service explore link renovation\" href=\"#\">\n                    Explore\n                    <svg data-kid=\"1-5-2-4-4-1\" data-name=\"service explore link arrow\" fill=\"none\" height=\"14\" stroke=\"currentColor\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"14\">\n                        <path d=\"M7 17L17 7M17 7H7M17 7V17\">\n                        </path>\n                    </svg>\n                </a>\n            </div>\n        </div>\n    </section>\n    <!-- 5. Meet the Studio -->\n    <section class=\"py-24 md:py-40 bg-[#FFFFFF]\" data-kid=\"1-6\" data-name=\"meet the studio section\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-12 gap-16 items-center\" data-kid=\"1-6-1\" data-name=\"meet the studio grid container\">\n            <div class=\"md:col-span-6 order-2 md:order-1\" data-kid=\"1-6-1-1\" data-name=\"meet the studio text block\">\n                <div class=\"text-[#707070] text-[11px] tracking-[0.25em] uppercase mb-4\" data-kid=\"1-6-1-1-1\" data-name=\"meet the studio section label\">\n                    <span class=\"ngi-rule\" data-kid=\"1-6-1-1-1-1\" data-name=\"meet the studio line icon\">\n                    </span>\n                    Meet the Studio\n                </div>\n                <h2 class=\"font-serif text-5xl md:text-7xl font-light tracking-tight leading-tight mb-8\" data-kid=\"1-6-1-1-2\" data-name=\"meet the studio title\">\n                    Thirteen people, one obsession:\n                    <br data-kid=\"1-6-1-1-2-1\" data-name=\"meet the studio title break\"/>\n                    <span class=\"italic text-[#707070]\" data-kid=\"1-6-1-1-2-2\" data-name=\"meet the studio title italic\">\n                        considered interiors.\n                    </span>\n                </h2>\n                <p class=\"text-[#1E1E1E]/80 text-lg leading-relaxed mb-12 max-w-xl\" data-kid=\"1-6-1-1-3\" data-name=\"meet the studio description\">\n                    Based in Bengaluru, we work unhurriedly across India. We believe spaces should feel inevitable, not trendy. Our commitment is to the detail—the way light hits a corner, the tactile grain of wood, the quiet of a well-designed room.\n                </p>\n                <a class=\"inline-flex items-center bg-[#171717] text-white px-10 py-5 text-[11px] tracking-[0.22em] uppercase hover:bg-[#C8A46A] transition-colors duration-500\" data-kid=\"1-6-1-1-4\" data-name=\"meet the studio story link\" href=\"#\">\n                    Our Story →\n                </a>\n            </div>\n            <div class=\"md:col-span-6 order-1 md:order-2\" data-kid=\"1-6-1-2\" data-name=\"meet the studio image container\">\n                <div class=\"relative aspect-[16/10] overflow-hidden bg-[#E7E2DA] shadow-[0_40px_100px_-20px_rgba(23,23,23,0.15)]\" data-kid=\"1-6-1-2-1\" data-name=\"meet the studio image wrapper\">\n                    <img alt=\"Studio\" class=\"w-full h-full object-cover grayscale-[0.3]\" data-kid=\"1-6-1-2-1-1\" data-name=\"meet the studio image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/34538288/pexels-photo-34538288.jpeg\"/>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- 6. Testimonials -->\n    <section class=\"py-24 md:py-40 bg-[#F6F4F1]\" data-kid=\"1-7\" data-name=\"testimonials section\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 mb-20 text-center\" data-kid=\"1-7-1\" data-name=\"testimonials header block\">\n            <div class=\"text-[#707070] text-[11px] tracking-[0.25em] uppercase mb-4\" data-kid=\"1-7-1-1\" data-name=\"testimonials section label\">\n                From Our Clients\n            </div>\n            <h2 class=\"font-serif text-5xl md:text-7xl font-light tracking-tight\" data-kid=\"1-7-1-2\" data-name=\"testimonials title\">\n                Words from the people\n                <br data-kid=\"1-7-1-2-1\" data-name=\"testimonials title break\"/>\n                we've designed for.\n            </h2>\n        </div>\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"1-7-2\" data-name=\"testimonials grid container\">\n            <div class=\"bg-white p-12 md:p-16 rounded-[22px] border border-[#E7E2DA] shadow-[0_30px_70px_-15px_rgba(23,23,23,0.06)] relative overflow-hidden group\" data-kid=\"1-7-2-1\" data-name=\"testimonial card one\">\n                <div class=\"absolute top-0 right-0 w-32 h-32 bg-[#C8A46A]/5 rounded-bl-full\" data-kid=\"1-7-2-1-1\" data-name=\"testimonial decorative element\">\n                </div>\n                <div class=\"text-[#C8A46A] mb-10\" data-kid=\"1-7-2-1-2\" data-name=\"testimonial quote icon container\">\n                    <svg data-kid=\"1-7-2-1-2-1\" data-name=\"testimonial quote icon\" fill=\"currentColor\" height=\"40\" opacity=\"0.4\" viewbox=\"0 0 24 24\" width=\"40\">\n                        <path d=\"M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C15.4647 8 15.017 8.44772 15.017 9V12C15.017 12.5523 14.5693 13 14.017 13H12.017V21H14.017ZM5.017 21L5.017 18C5.017 16.8954 5.91243 16 7.017 16H10.017C10.5693 16 11.017 15.5523 11.017 15V9C11.017 8.44772 10.5693 8 10.017 8H7.017C6.46472 8 6.017 8.44772 6.017 9V12C6.017 12.5523 5.56928 13 5.017 13H3.017V21H5.017Z\">\n                        </path>\n                    </svg>\n                </div>\n                <p class=\"font-serif text-2xl md:text-3xl leading-relaxed text-[#1E1E1E] mb-12\" data-kid=\"1-7-2-1-3\" data-name=\"testimonial quote text\">\n                    \"They listened more than they spoke. The result is a home that feels like us—only more composed.\"\n                </p>\n                <div class=\"flex items-center gap-4\" data-kid=\"1-7-2-1-4\" data-name=\"testimonial author block\">\n                    <div class=\"w-12 h-px bg-[#C8A46A]\" data-kid=\"1-7-2-1-4-1\" data-name=\"testimonial author line\">\n                    </div>\n                    <div data-kid=\"1-7-2-1-4-2\" data-name=\"testimonial author name details\">\n                        <div class=\"text-[11px] tracking-[0.25em] uppercase text-[#1E1E1E] font-semibold\" data-kid=\"1-7-2-1-4-2-1\" data-name=\"testimonial author name\">\n                            Aarav & Ishita Menon\n                        </div>\n                        <div class=\"text-xs text-[#707070] mt-1\" data-kid=\"1-7-2-1-4-2-2\" data-name=\"testimonial author description\">\n                            Homeowners · Bengaluru\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"bg-white p-12 md:p-16 rounded-[22px] border border-[#E7E2DA] shadow-[0_30px_70px_-15px_rgba(23,23,23,0.06)] relative overflow-hidden\" data-kid=\"1-7-2-2\" data-name=\"testimonial card two\">\n                <div class=\"absolute top-0 right-0 w-32 h-32 bg-[#C8A46A]/5 rounded-bl-full\" data-kid=\"1-7-2-2-1\" data-name=\"testimonial decorative element\">\n                </div>\n                <div class=\"text-[#C8A46A] mb-10\" data-kid=\"1-7-2-2-2\" data-name=\"testimonial quote icon container\">\n                    <svg data-kid=\"1-7-2-2-2-1\" data-name=\"testimonial quote icon\" fill=\"currentColor\" height=\"40\" opacity=\"0.4\" viewbox=\"0 0 24 24\" width=\"40\">\n                        <path d=\"M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C15.4647 8 15.017 8.44772 15.017 9V12C15.017 12.5523 14.5693 13 14.017 13H12.017V21H14.017ZM5.017 21L5.017 18C5.017 16.8954 5.91243 16 7.017 16H10.017C10.5693 16 11.017 15.5523 11.017 15V9C11.017 8.44772 10.5693 8 10.017 8H7.017C6.46472 8 6.017 8.44772 6.017 9V12C6.017 12.5523 5.56928 13 5.017 13H3.017V21H5.017Z\">\n                        </path>\n                    </svg>\n                </div>\n                <p class=\"font-serif text-2xl md:text-3xl leading-relaxed text-[#1E1E1E] mb-12\" data-kid=\"1-7-2-2-3\" data-name=\"testimonial quote text\">\n                    \"Every evening the apartment seems to exhale. That is the design.\"\n                </p>\n                <div class=\"flex items-center gap-4\" data-kid=\"1-7-2-2-4\" data-name=\"testimonial author block\">\n                    <div class=\"w-12 h-px bg-[#C8A46A]\" data-kid=\"1-7-2-2-4-1\" data-name=\"testimonial author line\">\n                    </div>\n                    <div data-kid=\"1-7-2-2-4-2\" data-name=\"testimonial author name details\">\n                        <div class=\"text-[11px] tracking-[0.25em] uppercase text-[#1E1E1E] font-semibold\" data-kid=\"1-7-2-2-4-2-1\" data-name=\"testimonial author name\">\n                            Karan Shroff\n                        </div>\n                        <div class=\"text-xs text-[#707070] mt-1\" data-kid=\"1-7-2-2-4-2-2\" data-name=\"testimonial author description\">\n                            Homeowner · Mumbai\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- 7. Consultation CTA -->\n    <section class=\"py-24 md:py-40 bg-[#171717] relative overflow-hidden\" data-kid=\"1-8\" data-name=\"consultation cta section\">\n        <div class=\"absolute inset-0 opacity-10 pointer-events-none\" data-kid=\"1-8-1\" data-name=\"cta background texture\" style=\"background-image: url('https://www.transparenttextures.com/patterns/pinstriped-suit.png');\">\n        </div>\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 relative z-10 text-center\" data-kid=\"1-8-2\" data-name=\"cta content container\">\n            <div class=\"text-[#C8A46A] text-[11px] tracking-[0.3em] uppercase mb-8\" data-kid=\"1-8-2-1\" data-name=\"cta section label\">\n                Ready to Begin\n            </div>\n            <h2 class=\"font-serif text-white text-6xl md:text-8xl lg:text-[110px] font-light tracking-tighter leading-[0.9] mb-12\" data-kid=\"1-8-2-2\" data-name=\"cta title\">\n                Tell us about the space\n                <br data-kid=\"1-8-2-2-1\" data-name=\"cta title line break\"/>\n                you're imagining.\n            </h2>\n            <p class=\"text-white/60 text-lg md:text-xl max-w-2xl mx-auto mb-16 leading-relaxed\" data-kid=\"1-8-2-3\" data-name=\"cta description\">\n                Ninety minutes, in our studio or yours. No presentations, no sales—just a conversation between the people who will design your space and the people who will live in it.\n            </p>\n            <a class=\"inline-flex items-center gap-4 bg-[#C8A46A] text-white hover:bg-[#D6B27A] px-12 py-6 text-[12px] tracking-[0.3em] uppercase transition-all duration-500 shadow-2xl shadow-black/40\" data-kid=\"1-8-2-4\" data-name=\"cta book button\" href=\"#\">\n                Book Your Consultation\n                <svg data-kid=\"1-8-2-4-1\" data-name=\"cta button arrow icon\" fill=\"none\" height=\"18\" stroke=\"currentColor\" stroke-width=\"1.5\" viewbox=\"0 0 24 24\" width=\"18\">\n                    <path d=\"M7 17L17 7M17 7H7M17 7V17\">\n                    </path>\n                </svg>\n            </a>\n        </div>\n    </section>\n    <!-- Footer -->\n    <footer class=\"bg-[#171717] border-t border-white/5 py-24\" data-kid=\"1-9\" data-name=\"footer container\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-4 gap-16 md:gap-8\" data-kid=\"1-9-1\" data-name=\"footer content grid\">\n            <div class=\"md:col-span-1\" data-kid=\"1-9-1-1\" data-name=\"footer brand block\">\n                <a class=\"flex items-center gap-3 mb-10\" data-kid=\"1-9-1-1-1\" data-name=\"footer brand name link\" href=\"#\">\n                    <span class=\"block w-2 h-2 bg-[#C8A46A]\" data-kid=\"1-9-1-1-1-1\" data-name=\"footer logo icon\">\n                    </span>\n                    <span class=\"font-serif text-2xl tracking-tight text-white\" data-kid=\"1-9-1-1-1-2\" data-name=\"footer brand name text\">\n                        NextGen\n                        <span class=\"italic text-[#C8A46A]\" data-kid=\"1-9-1-1-1-2-1\" data-name=\"footer brand name italic suffix\">\n                            Interiors\n                        </span>\n                    </span>\n                </a>\n                <p class=\"text-white/50 text-sm leading-relaxed max-w-xs\" data-kid=\"1-9-1-1-2\" data-name=\"footer brand description\">\n                    Quietly considered interiors for residences and workplaces across India. Est. 2013 in Bengaluru.\n                </p>\n            </div>\n            <div data-kid=\"1-9-1-2\" data-name=\"footer navigation block\">\n                <h5 class=\"text-[#C8A46A] text-[10px] tracking-[0.3em] uppercase mb-8\" data-kid=\"1-9-1-2-1\" data-name=\"footer navigation title\">\n                    Navigation\n                </h5>\n                <ul class=\"space-y-4\" data-kid=\"1-9-1-2-2\" data-name=\"footer navigation list\">\n                    <li data-kid=\"1-9-1-2-2-1\" data-name=\"footer nav link item\">\n                        <a class=\"text-white/70 hover:text-[#C8A46A] text-sm transition-colors\" data-kid=\"1-9-1-2-2-1-1\" data-name=\"footer nav link\" href=\"#\">\n                            About\n                        </a>\n                    </li>\n                    <li data-kid=\"1-9-1-2-2-2\" data-name=\"footer nav link item\">\n                        <a class=\"text-white/70 hover:text-[#C8A46A] text-sm transition-colors\" data-kid=\"1-9-1-2-2-2-1\" data-name=\"footer nav link\" href=\"#\">\n                            Process\n                        </a>\n                    </li>\n                    <li data-kid=\"1-9-1-2-2-3\" data-name=\"footer nav link item\">\n                        <a class=\"text-white/70 hover:text-[#C8A46A] text-sm transition-colors\" data-kid=\"1-9-1-2-2-3-1\" data-name=\"footer nav link\" href=\"#\">\n                            Portfolio\n                        </a>\n                    </li>\n                    <li data-kid=\"1-9-1-2-2-4\" data-name=\"footer nav link item\">\n                        <a class=\"text-white/70 hover:text-[#C8A46A] text-sm transition-colors\" data-kid=\"1-9-1-2-2-4-1\" data-name=\"footer nav link\" href=\"#\">\n                            Contact\n                        </a>\n                    </li>\n                </ul>\n            </div>\n            <div data-kid=\"1-9-1-3\" data-name=\"footer contact block\">\n                <h5 class=\"text-[#C8A46A] text-[10px] tracking-[0.3em] uppercase mb-8\" data-kid=\"1-9-1-3-1\" data-name=\"footer contact title\">\n                    Contact\n                </h5>\n                <ul class=\"space-y-4\" data-kid=\"1-9-1-3-2\" data-name=\"footer contact list\">\n                    <li class=\"text-white/70 text-sm\" data-kid=\"1-9-1-3-2-1\" data-name=\"footer email address\">\n                        studio@nextgeninteriors.com\n                    </li>\n                    <li class=\"text-white/70 text-sm\" data-kid=\"1-9-1-3-2-2\" data-name=\"footer phone number\">\n                        +91 98765 43210\n                    </li>\n                    <li class=\"text-white/70 text-sm\" data-kid=\"1-9-1-3-2-3\" data-name=\"footer office locations\">\n                        Bengaluru · Mumbai · Pune\n                    </li>\n                </ul>\n            </div>\n            <div data-kid=\"1-9-1-4\" data-name=\"footer social block\">\n                <h5 class=\"text-[#C8A46A] text-[10px] tracking-[0.3em] uppercase mb-8\" data-kid=\"1-9-1-4-1\" data-name=\"footer social title\">\n                    Social\n                </h5>\n                <ul class=\"space-y-4\" data-kid=\"1-9-1-4-2\" data-name=\"footer social list\">\n                    <li data-kid=\"1-9-1-4-2-1\" data-name=\"footer social link item\">\n                        <a class=\"text-white/70 hover:text-[#C8A46A] text-sm transition-colors\" data-kid=\"1-9-1-4-2-1-1\" data-name=\"footer social link\" href=\"#\">\n                            Instagram\n                        </a>\n                    </li>\n                    <li data-kid=\"1-9-1-4-2-2\" data-name=\"footer social link item\">\n                        <a class=\"text-white/70 hover:text-[#C8A46A] text-sm transition-colors\" data-kid=\"1-9-1-4-2-2-1\" data-name=\"footer social link\" href=\"#\">\n                            LinkedIn\n                        </a>\n                    </li>\n                    <li data-kid=\"1-9-1-4-2-3\" data-name=\"footer social link item\">\n                        <a class=\"text-white/70 hover:text-[#C8A46A] text-sm transition-colors\" data-kid=\"1-9-1-4-2-3-1\" data-name=\"footer social link\" href=\"#\">\n                            Pinterest\n                        </a>\n                    </li>\n                </ul>\n            </div>\n        </div>\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 mt-24 pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"1-9-2\" data-name=\"footer bottom bar\">\n            <p class=\"text-white/30 text-[10px] tracking-widest uppercase\" data-kid=\"1-9-2-1\" data-name=\"footer copyright text\">\n                © 2026 NextGen Interiors. All Rights Reserved.\n            </p>\n            <p class=\"text-white/30 text-[10px] tracking-widest uppercase italic\" data-kid=\"1-9-2-2\" data-name=\"footer quote text\">\n                Elegance is refusal.\n            </p>\n        </div>\n    </footer>\n</div>\n",
