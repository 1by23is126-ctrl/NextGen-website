      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@300;400;500;600&display=swap');\n\n  ::selection {\n    background-color: #C8A46A;\n    color: #FFFFFF;\n  }\n\n  .font-serif { font-family: 'Instrument Serif', serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .ngi-reveal {\n    animation: reveal 1.2s cubic-bezier(0.23, 1, 0.32, 1) forwards;\n    opacity: 0;\n    transform: translateY(20px);\n  }\n\n  @keyframes reveal {\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n\n  .ngi-rule {\n    display: inline-block;\n    width: 24px;\n    height: 1px;\n    background-color: currentColor;\n    vertical-align: middle;\n    margin-right: 12px;\n  }\n\n  /* Glassmorphism for Navbar on scroll simulation */\n  .nav-glass {\n    background: rgba(255, 255, 255, 0.88);\n    backdrop-filter: blur(12px);\n    border-bottom: 1px solid #E7E2DA;\n  }\n</style>\n<div class=\"font-sans text-[#1E1E1E] bg-[#F6F4F1] selection:bg-[#C8A46A] selection:text-white\" data-kid=\"1\" data-name=\"page layout container\">\n    <!-- Navigation (Simulated Scrolled State) -->\n    <header class=\"fixed top-0 left-0 right-0 z-50 nav-glass\" data-kid=\"1-1\" data-name=\"navigation header bar\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 flex items-center justify-between py-5\" data-kid=\"1-1-1\" data-name=\"navigation container\">\n            <a class=\"flex items-center gap-3 group\" data-kid=\"1-1-1-1\" data-name=\"brand logo and name link\" href=\"#\">\n                <span class=\"block w-2 h-2 bg-[#C8A46A]\" data-kid=\"1-1-1-1-1\" data-name=\"brand logo square icon\">\n                </span>\n                <span class=\"font-serif text-2xl tracking-tight text-[#1E1E1E]\" data-kid=\"1-1-1-1-2\" data-name=\"brand name text\">\n                    NextGen\n                    <span class=\"italic font-normal text-[#707070]\" data-kid=\"1-1-1-1-2-1\" data-name=\"brand name italic suffix text\">\n                        Interiors\n                    </span>\n                </span>\n            </a>\n            <nav class=\"hidden lg:flex items-center gap-10\" data-kid=\"1-1-1-2\" data-name=\"desktop navigation menu\">\n                <a class=\"text-[13px] tracking-wider uppercase text-[#1E1E1E] transition-colors hover:text-[#C8A46A]\" data-kid=\"1-1-1-2-1\" data-name=\"home link\" href=\"#\">\n                    Home\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[#1E1E1E]/70 transition-colors hover:text-[#C8A46A]\" data-kid=\"1-1-1-2-2\" data-name=\"about link\" href=\"#\">\n                    About\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[#1E1E1E]/70 transition-colors hover:text-[#C8A46A]\" data-kid=\"1-1-1-2-3\" data-name=\"services link\" href=\"#\">\n                    Services\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[#1E1E1E]/70 transition-colors hover:text-[#C8A46A]\" data-kid=\"1-1-1-2-4\" data-name=\"portfolio link\" href=\"#\">\n                    Portfolio\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[#1E1E1E]/70 transition-colors hover:text-[#C8A46A]\" data-kid=\"1-1-1-2-5\" data-name=\"process link\" href=\"#\">\n                    Process\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[#1E1E1E]/70 transition-colors hover:text-[#C8A46A]\" data-kid=\"1-1-1-2-6\" data-name=\"journal link\" href=\"#\">\n                    Journal\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[#1E1E1E]/70 transition-colors hover:text-[#C8A46A]\" data-kid=\"1-1-1-2-7\" data-name=\"contact link\" href=\"#\">\n                    Contact\n                </a>\n            </nav>\n            <div class=\"flex items-center gap-3\" data-kid=\"1-1-1-3\" data-name=\"navigation call-to-action wrapper\">\n                <a class=\"hidden md:inline-flex items-center bg-[#171717] text-white px-6 py-3 text-[11px] tracking-[0.22em] uppercase hover:bg-[#C8A46A] transition-colors duration-300\" data-kid=\"1-1-1-3-1\" data-name=\"book consultation button\" href=\"#\">\n                    Book Consultation\n                </a>\n            </div>\n        </div>\n    </header>\n    <!-- 1. Hero Section -->\n    <section class=\"relative h-screen min-h-[720px] overflow-hidden bg-[#171717] flex flex-col justify-end pb-24\" data-kid=\"1-2\" data-name=\"hero section\">\n        <!-- Background with Material Depth (Overlaying Grain & Gradient) -->\n        <div class=\"absolute inset-0 overflow-hidden\" data-kid=\"1-2-1\" data-name=\"hero background image container\">\n            <img alt=\"Luxury Interior\" class=\"absolute inset-0 w-full h-full object-cover scale-105\" data-kid=\"1-2-1-1\" data-name=\"hero background image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20418771/pexels-photo-20418771.jpeg\"/>\n            <div class=\"absolute inset-0 bg-gradient-to-b from-[#171717]/40 via-transparent to-[#171717]/80\" data-kid=\"1-2-1-2\" data-name=\"hero background gradient overlay\">\n            </div>\n        </div>\n        <div class=\"relative z-10 max-w-[1440px] mx-auto w-full px-6 md:px-12\" data-kid=\"1-2-2\" data-name=\"hero content container\">\n            <div class=\"max-w-4xl\" data-kid=\"1-2-2-1\" data-name=\"hero text content block\">\n                <div class=\"text-[#C8A46A] text-[11px] font-medium tracking-[0.22em] uppercase mb-6 ngi-reveal\" data-kid=\"1-2-2-1-1\" data-name=\"hero decorative line and label\" style=\"animation-delay: 0.2s;\">\n                    <span class=\"ngi-rule\" data-kid=\"1-2-2-1-1-1\" data-name=\"hero decorative line icon\">\n                    </span>\n                    Interior architecture · Est. 2013\n                </div>\n                <h1 class=\"font-serif text-white text-6xl md:text-8xl lg:text-[100px] font-light tracking-tighter leading-[0.9] mb-12\" data-kid=\"1-2-2-1-2\" data-name=\"hero headline\">\n                    <span class=\"block ngi-reveal\" data-kid=\"1-2-2-1-2-1\" data-name=\"hero headline first line\" style=\"animation-delay: 0.4s;\">\n                        Interiors that hold\n                    </span>\n                    <span class=\"block italic text-[#C8A46A] ngi-reveal\" data-kid=\"1-2-2-1-2-2\" data-name=\"hero headline italic line\" style=\"animation-delay: 0.6s;\">\n                        a quiet conversation\n                    </span>\n                    <span class=\"block ngi-reveal\" data-kid=\"1-2-2-1-2-3\" data-name=\"hero headline final line\" style=\"animation-delay: 0.8s;\">\n                        with their owners.\n                    </span>\n                </h1>\n                <div class=\"flex flex-col sm:flex-row gap-6 items-start ngi-reveal\" data-kid=\"1-2-2-1-3\" data-name=\"hero call-to-action buttons wrapper\" style=\"animation-delay: 1s;\">\n                    <a class=\"inline-flex items-center gap-3 bg-[#C8A46A] text-white hover:bg-[#D6B27A] px-10 py-5 text-[11px] tracking-[0.22em] uppercase transition-all duration-500 shadow-xl shadow-black/20\" data-kid=\"1-2-2-1-3-1\" data-name=\"hero primary book button\" href=\"#\">\n                        Book a Consultation\n                        <svg data-kid=\"1-2-2-1-3-1-1\" data-name=\"hero primary button arrow icon\" fill=\"none\" height=\"16\" stroke=\"currentColor\" stroke-width=\"1.5\" viewbox=\"0 0 24 24\" width=\"16\">\n                            <path d=\"M7 17L17 7M17 7H7M17 7V17\">\n                            </path>\n                        </svg>\n                    </a>\n                    <a class=\"inline-flex items-center gap-3 border border-white/30 text-white hover:bg-[#C8A46A] hover:border-[#C8A46A] px-10 py-5 text-[11px] tracking-[0.22em] uppercase transition-all duration-500\" data-kid=\"1-2-2-1-3-2\" data-name=\"hero secondary portfolio button\" href=\"#\">\n                        View Portfolio\n                    </a>\n                </div>\n            </div>\n        </div>\n        <!-- Scroll Indicator -->\n        <div class=\"absolute bottom-10 right-12 text-white/50 text-[10px] tracking-[0.4em] uppercase flex items-center gap-4 ngi-reveal\" data-kid=\"1-2-3\" data-name=\"scroll indicator container\" style=\"animation-delay: 1.2s;\">\n            <span data-kid=\"1-2-3-1\" data-name=\"scroll indicator label\">\n                Scroll\n            </span>\n            <span class=\"block w-12 h-px bg-white/30\" data-kid=\"1-2-3-2\" data-name=\"scroll indicator line icon\">\n            </span>\n        </div>\n    </section>\n    <!-- 2. Featured Projects -->\n    <section class=\"py-24 md:py-32 max-w-[1440px] mx-auto px-6 md:px-12\" data-kid=\"1-3\" data-name=\"featured projects section\">\n        <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20\" data-kid=\"1-3-1\" data-name=\"featured projects header\">\n            <div class=\"max-w-2xl\" data-kid=\"1-3-1-1\" data-name=\"featured projects title block\">\n                <div class=\"text-[#707070] text-[11px] tracking-[0.22em] uppercase mb-4\" data-kid=\"1-3-1-1-1\" data-name=\"featured projects section label\">\n                    <span class=\"ngi-rule\" data-kid=\"1-3-1-1-1-1\" data-name=\"featured projects line icon\">\n                    </span>\n                    Selected Works\n                </div>\n                <h2 class=\"font-serif text-5xl md:text-6xl font-light tracking-tight leading-tight\" data-kid=\"1-3-1-1-2\" data-name=\"featured projects main title\">\n                    Each project, an answer to a question only the client could ask.\n                </h2>\n            </div>\n            <a class=\"text-sm tracking-wider uppercase text-[#1E1E1E] border-b border-[#1E1E1E]/20 pb-1 hover:text-[#C8A46A] hover:border-[#C8A46A] transition-all\" data-kid=\"1-3-1-2\" data-name=\"all projects navigation link\" href=\"#\">\n                All projects →\n            </a>\n        </div>\n        <div class=\"grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-16\" data-kid=\"1-3-2\" data-name=\"featured projects grid container\">\n            <!-- Project 1 -->\n            <div class=\"md:col-span-7 group\" data-kid=\"1-3-2-1\" data-name=\"featured project primary card\">\n                <a class=\"block\" data-kid=\"1-3-2-1-1\" data-name=\"project link wrapper\" href=\"#\">\n                    <div class=\"relative aspect-[4/5] overflow-hidden bg-[#E7E2DA] shadow-[0_30px_60px_-15px_rgba(23,23,23,0.12)] transition-transform duration-700 hover:shadow-[0_40px_80px_-15px_rgba(23,23,23,0.18)]\" data-kid=\"1-3-2-1-1-1\" data-name=\"project image container\">\n                        <img alt=\"Project\" class=\"w-full h-full object-cover grayscale-[0.2] transition-transform duration-1000 group-hover:scale-105\" data-kid=\"1-3-2-1-1-1-1\" data-name=\"project image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/13201479/pexels-photo-13201479.jpeg\"/>\n                        <div class=\"absolute inset-0 border border-[#E7E2DA]/30\" data-kid=\"1-3-2-1-1-1-2\" data-name=\"project image border overlay\">\n                        </div>\n                    </div>\n                    <div class=\"flex items-end justify-between mt-8\" data-kid=\"1-3-2-1-1-2\" data-name=\"project details container\">\n                        <div data-kid=\"1-3-2-1-1-2-1\" data-name=\"project category and title container\">\n                            <div class=\"text-[10px] tracking-[0.25em] uppercase text-[#707070] mb-2\" data-kid=\"1-3-2-1-1-2-1-1\" data-name=\"project category label\">\n                                Residential · Bengaluru\n                            </div>\n                            <h3 class=\"font-serif text-3xl md:text-4xl group-hover:text-[#707070] transition-colors\" data-kid=\"1-3-2-1-1-2-1-2\" data-name=\"project title\">\n                                Residency HSR\n                            </h3>\n                        </div>\n                        <div class=\"w-10 h-10 rounded-full border border-[#E7E2DA] flex items-center justify-center text-[#1E1E1E] group-hover:bg-[#C8A46A] group-hover:border-[#C8A46A] group-hover:text-white transition-all duration-500\" data-kid=\"1-3-2-1-1-2-2\" data-name=\"project link arrow icon circle\">\n                            <svg data-kid=\"1-3-2-1-1-2-2-1\" data-name=\"project link arrow icon\" fill=\"none\" height=\"18\" stroke=\"currentColor\" stroke-width=\"1.5\" viewbox=\"0 0 24 24\" width=\"18\">\n                                <path d=\"M7 17L17 7M17 7H7M17 7V17\">\n                                </path>\n                            </svg>\n                        </div>\n                    </div>\n                </a>\n            </div>\n            <!-- Project 2 & 3 Column -->\n            <div class=\"md:col-span-5 flex flex-col gap-24\" data-kid=\"1-3-2-2\" data-name=\"featured projects secondary column\">\n                <div class=\"group\" data-kid=\"1-3-2-2-1\" data-name=\"project secondary card\">\n                    <a class=\"block\" data-kid=\"1-3-2-2-1-1\" data-name=\"secondary project link wrapper\" href=\"#\">\n                        <div class=\"relative aspect-[4/5] overflow-hidden bg-[#E7E2DA] shadow-[0_25px_50px_-12px_rgba(23,23,23,0.1)] transition-transform duration-700 hover:shadow-[0_35px_70px_-12px_rgba(23,23,23,0.15)]\" data-kid=\"1-3-2-2-1-1-1\" data-name=\"secondary project image container\">\n                            <img alt=\"Project\" class=\"w-full h-full object-cover grayscale-[0.2] transition-transform duration-1000 group-hover:scale-105\" data-kid=\"1-3-2-2-1-1-1-1\" data-name=\"secondary project image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/13219418/pexels-photo-13219418.jpeg\"/>\n                        </div>\n                        <div class=\"mt-8\" data-kid=\"1-3-2-2-1-1-2\" data-name=\"secondary project details container\">\n                            <div class=\"text-[10px] tracking-[0.25em] uppercase text-[#707070] mb-2\" data-kid=\"1-3-2-2-1-1-2-1\" data-name=\"secondary project category label\">\n                                Commercial · Mumbai\n                            </div>\n                            <h3 class=\"font-serif text-2xl md:text-3xl\" data-kid=\"1-3-2-2-1-1-2-2\" data-name=\"secondary project title\">\n                                The Creative Studio\n                            </h3>\n                        </div>\n                    </a>\n                </div>\n                <div class=\"group\" data-kid=\"1-3-2-2-2\" data-name=\"project tertiary card\">\n                    <a class=\"block\" data-kid=\"1-3-2-2-2-1\" data-name=\"tertiary project link wrapper\" href=\"#\">\n                        <div class=\"relative aspect-[4/5] overflow-hidden bg-[#E7E2DA] shadow-[0_25px_50px_-12px_rgba(23,23,23,0.1)] transition-transform duration-700 hover:shadow-[0_35px_70px_-12px_rgba(23,23,23,0.15)]\" data-kid=\"1-3-2-2-2-1-1\" data-name=\"tertiary project image container\">\n                            <img alt=\"Project\" class=\"w-full h-full object-cover grayscale-[0.2] transition-transform duration-1000 group-hover:scale-105\" data-kid=\"1-3-2-2-2-1-1-1\" data-name=\"tertiary project image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/34538288/pexels-photo-34538288.jpeg\"/>\n                        </div>\n                        <div class=\"mt-8\" data-kid=\"1-3-2-2-2-1-2\" data-name=\"tertiary project details container\">\n                            <div class=\"text-[10px] tracking-[0.25em] uppercase text-[#707070] mb-2\" data-kid=\"1-3-2-2-2-1-2-1\" data-name=\"tertiary project category label\">\n                                Residential · Pune\n                            </div>\n                            <h3 class=\"font-serif text-2xl md:text-3xl\" data-kid=\"1-3-2-2-2-1-2-2\" data-name=\"tertiary project title\">\n                                Casa Harmony\n                            </h3>\n                        </div>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- 3. Blueprint to Reality (Dark Section) -->\n    <section class=\"bg-[#171717] py-24 md:py-32 overflow-hidden\" data-kid=\"1-4\" data-name=\"process section\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 gap-20 items-center\" data-kid=\"1-4-1\" data-name=\"process content grid container\">\n            <div data-kid=\"1-4-1-1\" data-name=\"process content block\">\n                <div class=\"text-[#C8A46A] text-[11px] tracking-[0.25em] uppercase mb-6\" data-kid=\"1-4-1-1-1\" data-name=\"process section label\">\n                    <span class=\"ngi-rule\" data-kid=\"1-4-1-1-1-1\" data-name=\"process line icon\">\n                    </span>\n                    The Process\n                </div>\n                <h2 class=\"font-serif text-white text-5xl md:text-7xl font-light tracking-tight leading-tight mb-8\" data-kid=\"1-4-1-1-2\" data-name=\"process title\">\n                    From Blueprint\n                    <br data-kid=\"1-4-1-1-2-1\" data-name=\"process title line break\"/>\n                    <span class=\"italic text-[#C8A46A]\" data-kid=\"1-4-1-1-2-2\" data-name=\"process title italic text\">\n                        to Reality.\n                    </span>\n                </h2>\n                <p class=\"text-white/70 text-lg leading-relaxed max-w-lg mb-12\" data-kid=\"1-4-1-1-3\" data-name=\"process description text\">\n                    We don't just design spaces; we architect experiences. Every detail is a deliberate choice, every texture a planned conversation.\n                </p>\n                <div class=\"space-y-8\" data-kid=\"1-4-1-1-4\" data-name=\"process steps container\">\n                    <div class=\"flex gap-6\" data-kid=\"1-4-1-1-4-1\" data-name=\"process step 01\">\n                        <span class=\"font-serif text-3xl text-[#C8A46A] opacity-50\" data-kid=\"1-4-1-1-4-1-1\" data-name=\"step 01 number\">\n                            01\n                        </span>\n                        <div data-kid=\"1-4-1-1-4-1-2\" data-name=\"step 01 text block\">\n                            <h4 class=\"text-white text-xl mb-2\" data-kid=\"1-4-1-1-4-1-2-1\" data-name=\"step 01 title\">\n                                The Concept\n                            </h4>\n                            <p class=\"text-white/50 text-sm\" data-kid=\"1-4-1-1-4-1-2-2\" data-name=\"step 01 description\">\n                                Translating your vision into a cohesive architectural narrative.\n                            </p>\n                        </div>\n                    </div>\n                    <div class=\"flex gap-6\" data-kid=\"1-4-1-1-4-2\" data-name=\"process step 02\">\n                        <span class=\"font-serif text-3xl text-[#C8A46A] opacity-50\" data-kid=\"1-4-1-1-4-2-1\" data-name=\"step 02 number\">\n                            02\n                        </span>\n                        <div data-kid=\"1-4-1-1-4-2-2\" data-name=\"step 02 text block\">\n                            <h4 class=\"text-white text-xl mb-2\" data-kid=\"1-4-1-1-4-2-2-1\" data-name=\"step 02 title\">\n                                The Curation\n                            </h4>\n                            <p class=\"text-white/50 text-sm\" data-kid=\"1-4-1-1-4-2-2-2\" data-name=\"step 02 description\">\n                                Selecting materials that speak of quality and timelessness.\n                            </p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"relative\" data-kid=\"1-4-1-2\" data-name=\"process visual element container\">\n                <div class=\"aspect-[4/5] bg-[#262626] border border-white/5 p-4\" data-kid=\"1-4-1-2-1\" data-name=\"process image container\">\n                    <img alt=\"Process\" class=\"w-full h-full object-cover opacity-80\" data-kid=\"1-4-1-2-1-1\" data-name=\"process image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/34538288/pexels-photo-34538288.jpeg\"/>\n                </div>\n                <div class=\"absolute -bottom-10 -left-10 w-48 h-48 bg-[#C8A46A] opacity-10 blur-3xl\" data-kid=\"1-4-1-2-2\" data-name=\"process decorative blur effect\">\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- 4. Services Overview -->\n    <section class=\"py-24 md:py-40 bg-[#F6F4F1]\" data-kid=\"1-5\" data-name=\"services section\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 text-center mb-20\" data-kid=\"1-5-1\" data-name=\"services header block\">\n            <div class=\"text-[#707070] text-[11px] tracking-[0.25em] uppercase mb-4\" data-kid=\"1-5-1-1\" data-name=\"services section label\">\n                Studio Disciplines\n            </div>\n            <h2 class=\"font-serif text-5xl md:text-7xl font-light tracking-tight max-w-3xl mx-auto\" data-kid=\"1-5-1-2\" data-name=\"services title\">\n                Four disciplines. One studio.\n                <span class=\"italic text-[#707070]\" data-kid=\"1-5-1-2-1\" data-name=\"services title italic suffix\">\n                    Infinite possibilities.\n                </span>\n            </h2>\n        </div>\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\" data-kid=\"1-5-2\" data-name=\"services grid container\">\n            <!-- Service Card 1 -->\n            <div class=\"group bg-white p-8 md:p-10 rounded-[22px] border border-[#E7E2DA] shadow-[0_20px_60px_-15px_rgba(23,23,23,0.06)] transition-all duration-500 hover:-translate-y-2 hover:border-[#C8A46A]/30 hover:shadow-[0_30px_70px_-15px_rgba(23,23,23,0.1)]\" data-kid=\"1-5-2-1\" data-name=\"service card residential\">\n                <div class=\"w-12 h-12 mb-10 text-[#C8A46A]\" data-kid=\"1-5-2-1-1\" data-name=\"service card icon container\">\n                    <svg data-kid=\"1-5-2-1-1-1\" data-name=\"residential icon\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"square\" stroke-width=\"1.2\" viewbox=\"0 0 24 24\">\n                        <path d=\"M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z\">\n                        </path>\n                        <polyline points=\"9 22 9 12 15 12 15 22\">\n                        </polyline>\n                    </svg>\n                </div>\n                <h3 class=\"font-serif text-2xl md:text-3xl mb-4 group-hover:text-[#C8A46A] transition-colors\" data-kid=\"1-5-2-1-2\" data-name=\"service title residential\">\n                    Residential\n                </h3>\n                <p class=\"text-sm text-[#707070] leading-relaxed mb-8\" data-kid=\"1-5-2-1-3\" data-name=\"service description residential\">\n                    Crafting sanctuaries that reflect the quiet elegance of their owners.\n                </p>\n                <a class=\"inline-flex items-center gap-2 text-[11px] tracking-widest uppercase text-[#1E1E1E] font-medium group-hover:text-[#C8A46A] transition-colors\" data-kid=\"1-5-2-1-4\" data-name=\"service explore link residential\" href=\"#\">\n                    Explore\n                    <svg data-kid=\"1-5-2-1-4-1\" data-name=\"service explore link arrow\" fill=\"none\" height=\"14\" stroke=\"currentColor\" stroke-width=\"2\" viewbox=\"0 0 24 24\" width=\"14\">\n                        <path d=\"M7 17L17 7M17 7H7M17 7V17\">\n                        </path>\n                    </svg>\n                </a>\n            </div>\n            <!-- Service Car