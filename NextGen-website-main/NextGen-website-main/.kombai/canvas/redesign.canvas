    },
    "var_ba4a3f6890b5": {
      "type": "variant",
      "label": "Homepage - Redesign (The Architectural)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 4620,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Instrument+Serif:ital@0;1&display=swap');\n\n  :root {\n    --color-bg-light: #F6F4F1;\n    --color-surface: #FFFFFF;\n    --color-ink-primary: #1E1E1E;\n    --color-ink-secondary: #707070;\n    --color-border-stone: #E7E2DA;\n    --color-gold: #C8A46A;\n    --color-gold-hover: #D6B27A;\n    --color-dark-primary: #171717;\n    --color-dark-secondary: #262626;\n    --color-white: #FFFFFF;\n    --color-white-muted: rgba(255,255,255,0.75);\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: #1E1E1E;\n    background-color: #F6F4F1;\n    margin: 0;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .font-serif {\n    font-family: 'Instrument Serif', serif;\n  }\n\n  .nav-glass {\n    background: rgba(255, 255, 255, 0.88);\n    backdrop-filter: blur(12px);\n    border-bottom: 1px solid #E7E2DA;\n  }\n\n  ::selection {\n    background: #C8A46A;\n    color: white;\n  }\n\n  /* Custom utility for soft shadow from design system */\n  .shadow-soft {\n    box-shadow: 0 18px 50px rgba(23, 23, 23, 0.06);\n  }\n\n  .shadow-soft-hover:hover {\n    box-shadow: 0 24px 70px rgba(23, 23, 23, 0.12);\n  }\n</style>\n<div class=\"min-h-screen\" data-kid=\"1\" data-name=\"page layout container\">\n    <!-- Navbar -->\n    <header class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-500 py-6\" data-dynamic=\"true\" data-kid=\"1-1\" data-name=\"main navigation bar\" data-reason=\"styles like background, border, and padding replaced on scroll by GSAP ScrollTrigger\" id=\"navbar\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 flex items-center justify-between\" data-kid=\"1-1-1\" data-name=\"navigation content container\">\n            <div class=\"flex items-center gap-3\" data-kid=\"1-1-1-1\" data-name=\"logo container\">\n                <span class=\"block w-2.5 h-2.5 bg-[#C8A46A]\" data-kid=\"1-1-1-1-1\" data-name=\"logo accent square\">\n                </span>\n                <span class=\"font-serif text-2xl tracking-tight text-white transition-colors duration-500\" data-dynamic=\"true\" data-kid=\"1-1-1-1-2\" data-name=\"logo text\" data-reason=\"color replaced on scroll by GSAP ScrollTrigger\" id=\"logo-text\">\n                    NextGen\n                    <span class=\"italic font-normal text-[#C8A46A]\" data-kid=\"1-1-1-1-2-1\" data-name=\"logo text accent\">\n                        Interiors\n                    </span>\n                </span>\n            </div>\n            <nav class=\"hidden lg:flex items-center gap-12\" data-kid=\"1-1-1-2\" data-name=\"navigation links container\">\n                <a class=\"text-[12px] tracking-[0.18em] uppercase text-white hover:text-[#C8A46A] transition-colors\" data-dynamic=\"true\" data-kid=\"1-1-1-2-1\" data-name=\"navigation home link\" data-reason=\"color replaced on scroll by GSAP ScrollTrigger\" href=\"#\" id=\"nav-link-1\">\n                    Home\n                </a>\n                <a class=\"text-[12px] tracking-[0.18em] uppercase text-white/70 hover:text-[#C8A46A] transition-colors\" data-dynamic=\"true\" data-kid=\"1-1-1-2-2\" data-name=\"navigation about link\" data-reason=\"color replaced on scroll by GSAP ScrollTrigger\" href=\"#\" id=\"nav-link-2\">\n                    About\n                </a>\n                <a class=\"text-[12px] tracking-[0.18em] uppercase text-white/70 hover:text-[#C8A46A] transition-colors\" data-dynamic=\"true\" data-kid=\"1-1-1-2-3\" data-name=\"navigation services link\" data-reason=\"color replaced on scroll by GSAP ScrollTrigger\" href=\"#\" id=\"nav-link-3\">\n                    Services\n                </a>\n                <a class=\"text-[12px] tracking-[0.18em] uppercase text-white/70 hover:text-[#C8A46A] transition-colors\" data-dynamic=\"true\" data-kid=\"1-1-1-2-4\" data-name=\"navigation portfolio link\" data-reason=\"color replaced on scroll by GSAP ScrollTrigger\" href=\"#\" id=\"nav-link-4\">\n                    Portfolio\n                </a>\n                <a class=\"text-[12px] tracking-[0.18em] uppercase text-white/70 hover:text-[#C8A46A] transition-colors\" data-dynamic=\"true\" data-kid=\"1-1-1-2-5\" data-name=\"navigation contact link\" data-reason=\"color replaced on scroll by GSAP ScrollTrigger\" href=\"#\" id=\"nav-link-5\">\n                    Contact\n                </a>\n            </nav>\n            <div class=\"flex items-center gap-4\" data-kid=\"1-1-1-3\" data-name=\"navigation cta container\">\n                <a class=\"bg-white text-[#171717] px-7 py-3.5 text-[11px] tracking-[0.22em] uppercase hover:bg-[#C8A46A] hover:text-white transition-all duration-300\" data-dynamic=\"true\" data-kid=\"1-1-1-3-1\" data-name=\"navigation book consultation button\" data-reason=\"colors replaced on scroll by GSAP ScrollTrigger\" href=\"#\" id=\"nav-cta\">\n                    Book Consultation\n                </a>\n            </div>\n        </div>\n    </header>\n    <!-- Hero Section (Dark) -->\n    <section class=\"relative h-screen min-h-[750px] overflow-hidden bg-[#171717] flex items-end pb-32\" data-kid=\"1-2\" data-name=\"hero section\">\n        <div class=\"absolute inset-0\" data-kid=\"1-2-1\" data-name=\"hero image background container\">\n            <img alt=\"Luxury Interior Hero\" class=\"w-full h-full object-cover opacity-60\" data-dynamic=\"true\" data-kid=\"1-2-1-1\" data-name=\"hero background image\" data-reason=\"y-axis position offset adjusted by GSAP ScrollTrigger\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20418771/pexels-photo-20418771.jpeg?auto=format&w=1920&q=80&fit=crop\"/>\n            <div class=\"absolute inset-0 bg-gradient-to-b from-[#171717]/40 via-[#171717]/10 to-[#171717]/90\" data-kid=\"1-2-1-2\" data-name=\"hero overlay gradient\">\n            </div>\n        </div>\n        <div class=\"relative w-full max-w-[1440px] mx-auto px-6 md:px-12\" data-k