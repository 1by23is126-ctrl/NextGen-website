ian Deep) -->\n    <section class=\"py-40 bg-[#171717] overflow-hidden relative\" data-kid=\"1-4\" data-name=\"process section\">\n        <div class=\"absolute top-0 right-0 w-1/3 h-full bg-[#262626]/20 skew-x-12 translate-x-1/2\" data-kid=\"1-4-1\" data-name=\"decorative skewed background\">\n        </div>\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 relative z-10\" data-kid=\"1-4-2\" data-name=\"process content container\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-24 items-center\" data-kid=\"1-4-2-1\" data-name=\"process content layout\">\n                <div data-kid=\"1-4-2-1-1\" data-name=\"process details block\">\n                    <div class=\"flex items-center gap-6 mb-10\" data-kid=\"1-4-2-1-1-1\" data-name=\"process subheadline block\">\n                        <span class=\"w-12 h-px bg-[#C8A46A]\" data-kid=\"1-4-2-1-1-1-1\" data-name=\"process subheadline line\">\n                        </span>\n                        <span class=\"text-[11px] tracking-[0.28em] uppercase text-[#C8A46A] font-semibold\" data-kid=\"1-4-2-1-1-1-2\" data-name=\"process subheadline text\">\n                            The Signature Experience\n                        </span>\n                    </div>\n                    <h2 class=\"font-serif text-6xl md:text-7xl font-light tracking-tight leading-[1.02] text-white mb-10\" data-kid=\"1-4-2-1-1-2\" data-name=\"process main headline\">\n                        From Blueprint\n                        <br data-kid=\"1-4-2-1-1-2-1\" data-name=\"process headline break\"/>\n                        <span class=\"italic text-[#C8A46A]\" data-kid=\"1-4-2-1-1-2-2\" data-name=\"process headline italic span\">\n                            to Reality.\n                        </span>\n                    </h2>\n                    <p class=\"text-white/70 text-xl leading-relaxed max-w-lg mb-16 font-light\" data-kid=\"1-4-2-1-1-3\" data-name=\"process description text\">\n                        We architect emotions through space. Every line is a commitment to a physical reality that ages gracefully with time.\n                    </p>\n                    <div class=\"space-y-12\" data-kid=\"1-4-2-1-1-4\" data-name=\"process steps list\">\n                        <div class=\"flex gap-8 group\" data-kid=\"1-4-2-1-1-4-1\" data-name=\"process step one\">\n                            <span class=\"font-serif text-4xl text-[#C8A46A] opacity-30 group-hover:opacity-100 transition-opacity\" data-kid=\"1-4-2-1-1-4-1-1\" data-name=\"step number\">\n                                01\n                            </span>\n                            <div data-kid=\"1-4-2-1-1-4-1-2\" data-name=\"step details container\">\n                                <h4 class=\"text-white font-medium mb-3 tracking-widest uppercase text-[11px]\" data-kid=\"1-4-2-1-1-4-1-2-1\" data-name=\"step title\">\n                                    Conceptual Depth\n                                </h4>\n                                <p class=\"text-white/50 text-base leading-relaxed max-w-sm\" data-kid=\"1-4-2-1-1-4-1-2-2\" data-name=\"step description\">\n                                    Starting with a quiet conversation to understand the soul of your intended space.\n                                </p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-8 group\" data-kid=\"1-4-2-1-1-4-2\" data-name=\"process step two\">\n                            <span class=\"font-serif text-4xl text-[#C8A46A] opacity-30 group-hover:opacity-100 transition-opacity\" data-kid=\"1-4-2-1-1-4-2-1\" data-name=\"step number\">\n                                02\n                            </span>\n                            <div data-kid=\"1-4-2-1-1-4-2-2\" data-name=\"step details container\">\n                                <h4 class=\"text-white font-medium mb-3 tracking-widest uppercase text-[11px]\" data-kid=\"1-4-2-1-1-4-2-2-1\" data-name=\"step title\">\n                                    Material Alchemy\n                                </h4>\n                                <p class=\"text-white/50 text-base leading-relaxed max-w-sm\" data-kid=\"1-4-2-1-1-4-2-2-2\" data-name=\"step description\">\n                                    Selecting finishes that interact with light and texture in profoundly unique ways.\n                                </p>\n                            </div>\n                        </div>\n                        <div class=\"flex gap-8 group\" data-kid=\"1-4-2-1-1-4-3\" data-name=\"process step three\">\n                            <span class=\"font-serif text-4xl text-[#C8A46A] opacity-30 group-hover:opacity-100 transition-opacity\" data-kid=\"1-4-2-1-1-4-3-1\" data-name=\"step number\">\n                                03\n                            </span>\n                            <div data-kid=\"1-4-2-1-1-4-3-2\" data-name=\"step details container\">\n                                <h4 class=\"text-white font-medium mb-3 tracking-widest uppercase text-[11px]\" data-kid=\"1-4-2-1-1-4-3-2-1\" data-name=\"step title\">\n                                    Precision Execution\n                                </h4>\n                                <p class=\"text-white/50 text-base leading-relaxed max-w-sm\" data-kid=\"1-4-2-1-1-4-3-2-2\" data-name=\"step description\">\n                                    Thirteen people, one obsession: delivering perfection down to the finest detail.\n                                </p>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"relative\" data-kid=\"1-4-2-1-2\" data-name=\"process image container\">\n                    <div class=\"aspect-[4/5] rounded-sm overflow-hidden border border-white/5 shadow-2xl\" data-kid=\"1-4-2-1-2-1\" data-name=\"process card wrapper\">\n                        <img alt=\"Architectural Process\" class=\"w-full h-full object-cover\" data-kid=\"1-4-2-1-2-1-1\" data-name=\"process image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/13219418/pexels-photo-13219418.jpeg?auto=format&w=1200&q=80&fit=crop\"/>\n                    </div>\n                    <div class=\"absolute -bottom-12 -left-12 bg-[#C8A46A] p-14 text-white hidden md:block shadow-2xl\" data-kid=\"1-4-2-1-2-2\" data-name=\"experience badge container\">\n                        <span class=\"block text-[64px] font-serif leading-none mb-4\" data-kid=\"1-4-2-1-2-2-1\" data-name=\"experience number\">\n                            12+\n                        </span>\n                        <span class=\"block text-[11px] tracking-[0.3em] uppercase leading-relaxed font-medium\" data-kid=\"1-4-2-1-2-2-2\" data-name=\"experience text\">\n                            Years of\n                            <br data-kid=\"1-4-2-1-2-2-2-1\" data-name=\"experience text break\"/>\n                            Studio Excellence\n                        </span>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Services (Ivory Canvas) -->\n    <section class=\"py-40 bg-[#F6F4F1]\" data-kid=\"1-5\" data-name=\"services section\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12\" data-kid=\"1-5-1\" data-name=\"services container\">\n            <div class=\"mb-24\" data-kid=\"1-5-1-1\" data-name=\"services header block\">\n                <div class=\"flex items-center gap-5 mb-8\" data-kid=\"1-5-1-1-1\" data-name=\"services subheadline block\">\n                    <span class=\"w-10 h-px bg-[#1E1E1E]\" data-kid=\"1-5-1-1-1-1\" data-name=\"services subheadline line\">\n                    </span>\n                    <span class=\"text-[11px] tracking-[0.25em] uppercase text-[#707070] font-medium\" data-kid=\"1-5-1-1-1-2\" data-name=\"services subheadline text\">\n                        Four Disciplines\n                    </span>\n                </div>\n                <h2 class=\"font-serif text-5xl md:text-6xl lg:text-7xl font-light tracking-tight leading-[1.05] text-[#1E1E1E] max-w-4xl\" data-kid=\"1-5-1-1-2\" data-name=\"services main headline\">\n                    One studio.\n                    <br data-kid=\"1-5-1-1-2-1\" data-name=\"services headline break\"/>\n                    Infinite possibilities.\n                </h2>\n            </div>\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"1-5-1-2\" data-name=\"services grid\">\n                <!-- Service 1 -->\n                <a class=\"group block relative bg-white border border-[#E7E2DA] rounded-[22px] overflow-hidden shadow-soft shadow-soft-hover transition-all duration-700\" data-kid=\"1-5-1-2-1\" data-name=\"service card one\" href=\"#\">\n                    <div class=\"aspect-[16/10] overflow-hidden bg-[#E7E2DA] relative\" data-kid=\"1-5-1-2-1-1\" data-name=\"service image container\">\n                        <img alt=\"Residential Service\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" data-kid=\"1-5-1-2-1-1-1\" data-name=\"service image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20418771/pexels-photo-20418771.jpeg?auto=format&w=1200&q=80&fit=crop\"/>\n                        <div class=\"absolute inset-0 bg-[#171717]/5 group-hover:bg-transparent transition-colors duration-500\" data-kid=\"1-5-1-2-1-1-2\" data-name=\"service image overlay\">\n                        </div>\n                    </div>\n                    <div class=\"p-12\" data-kid=\"1-5-1-2-1-2\" data-name=\"service details container\">\n                        <span class=\"text-[11px] tracking-[0.3em] uppercase text-[#C8A46A] mb-6 block font-bold\" data-kid=\"1-5-1-2-1-2-1\" data-name=\"service index number\">\n                            01\n                        </span>\n                        <h3 class=\"font-serif text-4xl mb-6 text-[#1E1E1E] group-hover:text-[#C8A46A] transition-colors\" data-kid=\"1-5-1-2-1-2-2\" data-name=\"service title\">\n                            Residential Interiors\n                        </h3>\n                        <p class=\"text-[#707070] text-base leading-relaxed mb-10 font-light\" data-kid=\"1-5-1-2-1-2-3\" data-name=\"service description\">\n                            Creating homes that are deeply personal, reflecting the silent stories of those who live within them with architectural restraint.\n                        </p>\n                        <div class=\"flex items-center gap-3 text-[11px] tracking-[0.3em] uppercase text-[#1E1E1E] font-semibold border-b border-[#1E1E1E]/10 pb-1 w-fit group-hover:border-[#C8A46A] group-hover:text-[#C8A46A] transition-all\" data-kid=\"1-5-1-2-1-2-4\" data-name=\"service explore button\">\n                            Explore Service\n                            <i class=\"ph ph-arrow-right\" data-kid=\"1-5-1-2-1-2-4-1\" data-name=\"right arrow icon\">\n                            </i>\n                        </div>\n                    </div>\n                </a>\n                <!-- Service 2 -->\n                <a class=\"group block relative bg-white border border-[#E7E2DA] rounded-[22px] overflow-hidden shadow-soft shadow-soft-hover transition-all duration-700\" data-kid=\"1-5-1-2-2\" data-name=\"service card two\" href=\"#\">\n                    <div class=\"aspect-[16/10] overflow-hidden bg-[#E7E2DA] relative\" data-kid=\"1-5-1-2-2-1\" data-name=\"service image container\">\n                        <img alt=\"Commercial Service\" class=\"w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" data-kid=\"1-5-1-2-2-1-1\" data-name=\"service image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/13201479/pexels-photo-13201479.jpeg?auto=format&w=1200&q=80&fit=crop\"/>\n                        <div class=\"absolute inset-0 bg-[#171717]/5 group-hover:bg-transparent transition-colors duration-500\" data-kid=\"1-5-1-2-2-1-2\" data-name=\"service image overlay\">\n                        </div>\n                    </div>\n                    <div class=\"p-12\" data-kid=\"1-5-1-2-2-2\" data-name=\"service details container\">\n                        <span class=\"text-[11px] tracking-[0.3em] uppercase text-[#C8A46A] mb-6 block font-bold\" data-kid=\"1-5-1-2-2-2-1\" data-name=\"service index number\">\n                            02\n                        </span>\n                        <h3 class=\"font-serif text-4xl mb-6 text-[#1E1E1E] group-hover:text-[#C8A46A] transition-colors\" data-kid=\"1-5-1-2-2-2-2\" data-name=\"service title\">\n                            Commercial Spaces\n                        </h3>\n                        <p class=\"text-[#707070] text-base leading-relaxed mb-10 font-light\" data-kid=\"1-5-1-2-2-2-3\" data-name=\"service description\">\n                            Elevating workplaces into meaningful environments that inspire collective productivity and reinforce brand character.\n                        </p>\n                        <div class=\"flex items-center gap-3 text-[11px] tracking-[0.3em] uppercase text-[#1E1E1E] font-semibold border-b border-[#1E1E1E]/10 pb-1 w-fit group-hover:border-[#C8A46A] group-hover:text-[#C8A46A] transition-all\" data-kid=\"1-5-1-2-2-2-4\" data-name=\"service explore button\">\n                            Explore Service\n                            <i class=\"ph ph-arrow-right\" data-kid=\"1-5-1-2-2-2-4-1\" data-name=\"right arrow icon\">\n                            </i>\n                        </div>\n                    </div>\n                </a>\n            </div>\n        </div>\n    </section>\n    <!-- Meet the Studio (Pure Surface) -->\n    <section class=\"py-40 bg-[#FFFFFF]\" data-kid=\"1-6\" data-name=\"studio section\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12\" data-kid=\"1-6-1\" data-name=\"studio container\">\n            <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-24 items-center\" data-kid=\"1-6-1-1\" data-name=\"studio layout block\">\n                <div class=\"lg:col-span-5\" data-kid=\"1-6-1-1-1\" data-name=\"studio image wrapper\">\n                    <div class=\"aspect-[4/5] overflow-hidden rounded-sm border border-[#E7E2DA] relative group\" data-kid=\"1-6-1-1-1-1\" data-name=\"studio image container\">\n                        <img alt=\"Studio Life\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:grayscale-0 group-hover:scale-105\" data-kid=\"1-6-1-1-1-1-1\" data-name=\"studio image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/34538288/pexels-photo-34538288.jpeg?auto=format&w=1200&q=80&fit=crop\"/>\n                    </div>\n                </div>\n                <div class=\"lg:col-span-6 lg:col-start-7\" data-kid=\"1-6-1-1-2\" data-name=\"studio text block\">\n                    <div class=\"flex items-center gap-5 mb-10\" data-kid=\"1-6-1-1-2-1\" data-name=\"studio subheadline block\">\n                        <span class=\"w-10 h-px bg-[#1E1E1E]\" data-kid=\"1-6-1-1-2-1-1\" data-name=\"studio subheadline line\">\n                        </span>\n                        <span class=\"text-[11px] tracking-[0.25em] uppercase text-[#707070] font-medium\" data-kid=\"1-6-1-1-2-1-2\" data-name=\"studio subheadline text\">\n                            The Practice\n                        </span>\n                    </div>\n                    <h2 class=\"font-serif text-5xl md:text-7xl font-light tracking-tight leading-[1.05] text-[#1E1E1E] mb-10\" data-kid=\"1-6-1-1-2-2\" data-name=\"studio main headline\">\n                        Thirteen people,\n                        <br data-kid=\"1-6-1-1-2-2-1\" data-name=\"headline break\"/>\n                        one obsession:\n                        <br data-kid=\"1-6-1-1-2-2-2\" data-name=\"headline break\"/>\n                        <em class=\"text-[#707070]\" data-kid=\"1-6-1-1-2-2-3\" data-name=\"headline italic emphasis\">\n                            considered interiors.\n                        </em>\n                    </h2>\n                    <p class=\"text-[#1E1E1E]/80 text-xl leading-relaxed mb-14 font-light\" data-kid=\"1-6-1-1-2-3\" data-name=\"studio description text\">\n                        Based in Bengaluru, we design residential and commercial interior architecture across India. What unites us isn't location—it's an unwavering commitment to detail and a belief that spaces should feel inevitable.\n                    </p>\n                    <div class=\"grid grid-cols-1 sm:grid-cols-2 gap-12 border-t border-[#E7E2DA] pt-16\" data-kid=\"1-6-1-1-2-4\" data-name=\"studio values grid\">\n                        <div data-kid=\"1-6-1-1-2-4-1\" data-name=\"value column one\">\n                            <h4 class=\"text-[11px] tracking-[0.3em] uppercase text-[#C8A46A] font-bold mb-5\" data-kid=\"1-6-1-1-2-4-1-1\" data-name=\"value title\">\n                                Design-Led\n                            </h4>\n                            <p class=\"text-[15px] text-[#707070] leading-relaxed font-light\" data-kid=\"1-6-1-1-2-4-1-2\" data-name=\"value description\">\n                                Every project is guided by senior architects from first sketch to final handover.\n                            </p>\n                        </div>\n                        <div data-kid=\"1-6-1-1-2-4-2\" data-name=\"value column two\">\n                            <h4 class=\"text-[11px] tracking-[0.3em] uppercase text-[#C8A46A] font-bold mb-5\" data-kid=\"1-6-1-1-2-4-2-1\" data-name=\"value title\">\n                                Material First\n                            </h4>\n                            <p class=\"text-[15px] text-[#707070] leading-relaxed font-light\" data-kid=\"1-6-1-1-2-4-2-2\" data-name=\"value description\">\n                                We review finishes in our studio under daylight and lamplight, never from a catalogue.\n                            </p>\n                        </div>\n                    </div>\n                    <a class=\"mt-20 inline-flex items-center gap-4 text-[12px] tracking-[0.3em] uppercase text-[#1E1E1E] font-bold group border-b border-[#1E1E1E]/10 pb-2 hover:border-[#C8A46A] hover:text-[#C8A46A] transition-all\" data-kid=\"1-6-1-1-2-5\" data-name=\"studio call-to-action button\" href=\"#\">\n                        Learn more about us\n                        <i class=\"ph ph-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"1-6-1-1-2-5-1\" data-name=\"right arrow icon\">\n                        </i>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Testimonials (Ivory Canvas) -->\n    <section class=\"py-40 bg-[#F6F4F1]\" data-kid=\"1-7\" data-name=\"testimonials section\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12\" data-kid=\"1-7-1\" data-name=\"testimonials container\">\n            <div class=\"flex flex-col md:flex-row md:items-end justify-between gap-12 mb-28\" data-kid=\"1-7-1-1\" data-name=\"testimonials header block\">\n                <div class=\"max-w-3xl\" data-kid=\"1-7-1-1-1\" data-name=\"testimonials subheadline block\">\n                    <div class=\"flex items-center gap-5 mb-8\" data-kid=\"1-7-1-1-1-1\" data-name=\"testimonials subheadline line\">\n                        <span class=\"w-10 h-px bg-[#1E1E1E]\" data-kid=\"1-7-1-1-1-1-1\">\n                        </span>\n                        <span class=\"text-[11px] tracking-[0.25em] uppercase text-[#707070] font-medium\" data-kid=\"1-7-1-1-1-1-2\" data-name=\"testimonials subheadline text\">\n                            Voices\n                        </span>\n                    </div>\n                    <h2 class=\"font-serif text-5xl md:text-6xl lg:text-7xl font-light tracking-tight leading-[1.05] text-[#1E1E1E]\" data-kid=\"1-7-1-1-1-2\" data-name=\"testimonials main headline\">\n                        Words from the people\n                        <br data-kid=\"1-7-1-1-1-2-1\" data-name=\"headline break\"/>\n                        we've designed for.\n                    </h2>\n                </div>\n            </div>\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\" data-kid=\"1-7-1-2\" data-name=\"testimonials grid\">\n                <!-- Testimonial 1 -->\n                <div class=\"bg-white p-14 rounded-[22px] border border-[#E7E2DA] shadow-soft relative group\" data-kid=\"1-7-1-2-1\" data-name=\"testimonial card one\">\n                    <div class=\"absolute top-14 right-14 opacity-10\" data-kid=\"1-7-1-2-1-1\" data-name=\"testimonial icon wrapper\">\n                        <i class=\"ph ph-quotes text-7xl text-[#C8A46A]\" data-kid=\"1-7-1-2-1-1-1\" data-name=\"quote icon\">\n                        </i>\n                    </div>\n                    <p class=\"font-serif text-3xl md:text-4xl font-light text-[#1E1E1E] leading-relaxed mb-16 relative z-10\" data-kid=\"1-7-1-2-1-2\" data-name=\"testimonial text\">\n                        \"They listened more than they spoke. The result is a home that feels like us—only more composed.\"\n                    </p>\n                    <div class=\"flex items-center gap-6 pt-12 border-t border-[#E7E2DA]\" data-kid=\"1-7-1-2-1-3\" data-name=\"testimonial author block\">\n                        <img alt=\"Client Avatar\" class=\"w-16 h-16 rounded-full grayscale border border-[#E7E2DA]\" data-kid=\"1-7-1-2-1-3-1\" data-name=\"author avatar\" decoding=\"async\" loading=\"lazy\" src=\"https://i.pravatar.cc/120?u=aarav\"/>\n                        <div data-kid=\"1-7-1-2-1-3-2\" data-name=\"author details container\">\n                            <h5 class=\"text-[12px] tracking-[0.25em] uppercase text-[#1E1E1E] font-bold\" data-kid=\"1-7-1-2-1-3-2-1\" data-name=\"author name\">\n                                Aarav & Ishita Menon\n                            </h5>\n                            <span class=\"text-[11px] tracking-[0.1em] text-[#707070] font-light\" data-kid=\"1-7-1-2-1-3-2-2\" data-name=\"author location\">\n                                Homeowners · Bengaluru\n                            </span>\n                        </div>\n                    </div>\n                </div>\n                <!-- Testimonial 2 -->\n                <div class=\"bg-white p-14 rounded-[22px] border border-[#E7E2DA] shadow-soft relative group\" data-kid=\"1-7-1-2-2\" data-name=\"testimonial card two\">\n                    <div class=\"absolute top-14 right-14 opacity-10\" data-kid=\"1-7-1-2-2-1\" data-name=\"testimonial icon wrapper\">\n                        <i class=\"ph ph-quotes text-7xl text-[#C8A46A]\" data-kid=\"1-7-1-2-2-1-1\" data-name=\"quote icon\">\n                        </i>\n                    </div>\n                    <p class=\"font-serif text-3xl md:text-4xl font-light text-[#1E1E1E] leading-relaxed mb-16 relative z-10\" data-kid=\"1-7-1-2-2-2\" data-name=\"testimonial text\">\n                        \"Every evening the apartment seems to exhale. That is the essence of truly considered design.\"\n                    </p>\n                    <div class=\"flex items-center gap-6 pt-12 border-t border-[#E7E2DA]\" data-kid=\"1-7-1-2-2-3\" data-name=\"testimonial author block\">\n                        <img alt=\"Client Avatar\" class=\"w-16 h-16 rounded-full grayscale border border-[#E7E2DA]\" data-kid=\"1-7-1-2-2-3-1\" data-name=\"author avatar\" decoding=\"async\" loading=\"lazy\" src=\"https://i.pravatar.cc/120?u=karan\"/>\n                        <div data-kid=\"1-7-1-2-2-3-2\" data-name=\"author details container\">\n                            <h5 class=\"text-[12px] tracking-[0.25em] uppercase text-[#1E1E1E] font-bold\" data-kid=\"1-7-1-2-2-3-2-1\" data-name=\"author name\">\n                                Karan Shroff\n                            </h5>\n                            <span class=\"text-[11px] tracking-[0.1em] text-[#707070] font-light\" data-kid=\"1-7-1-2-2-3-2-2\" data-name=\"author location\">\n                                Homeowner · Mumbai\n                            </span>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Final CTA (Obsidian Deep) -->\n    <section class=\"py-40 px-6 md:px-12 bg-[#F6F4F1]\" data-kid=\"1-8\" data-name=\"final cta section\">\n        <div class=\"max-w-[1440px] mx-auto bg-[#171717] rounded-sm p-20 md:p-32 relative overflow-hidden group\" data-kid=\"1-8-1\" data-name=\"final cta inner container\">\n            <div class=\"absolute inset-0 opacity-10 transition-opacity duration-1000 group-hover:opacity-20\" data-kid=\"1-8-1-1\" data-name=\"background image container\">\n                <img alt=\"Background Texture\" class=\"w-full h-full object-cover\" data-kid=\"1-8-1-1-1\" data-name=\"background image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/20418771/pexels-photo-20418771.jpeg?auto=format&w=1920&q=80&fit=crop\"/>\n            </div>\n            <div class=\"relative z-10 max-w-5xl\" data-kid=\"1-8-1-2\" data-name=\"cta content wrapper\">\n                <div class=\"flex items-center gap-6 mb-10\" data-kid=\"1-8-1-2-1\" data-name=\"cta subheadline block\">\n                    <span class=\"w-12 h-px bg-[#C8A46A]\" data-kid=\"1-8-1-2-1-1\" data-name=\"cta subheadline line\">\n                    </span>\n                    <span class=\"text-[11px] tracking-[0.3em] uppercase text-[#C8A46A] font-bold\" data-kid=\"1-8-1-2-1-2\" data-name=\"cta subheadline text\">\n                        Ready to Begin\n                    </span>\n                </div>\n                <h2 class=\"font-serif text-6xl md:text-8xl font-light tracking-tight leading-[1.02] text-white mb-12\" data-kid=\"1-8-1-2-2\" data-name=\"cta main headline\">\n                    Tell us about the space\n                    <br data-kid=\"1-8-1-2-2-1\" data-name=\"headline break\"/>\n                    you're imagining.\n                </h2>\n                <p class=\"text-white/60 text-xl leading-relaxed max-w-2xl mb-16 font-light\" data-kid=\"1-8-1-2-3\" data-name=\"cta description\">\n                    Ninety minutes, in our studio or yours. No presentations, no sales—just a quiet conversation between the people who will design your space and you.\n                </p>\n                <a class=\"inline-flex items-center gap-5 bg-[#C8A46A] text-white hover:bg-[#D6B27A] px-14 py-7 text-[12px] tracking-[0.4em] uppercase transition-all duration-300 font-bold shadow-2xl\" data-kid=\"1-8-1-2-4\" data-name=\"book consultation button\" href=\"#\">\n                    Book Consultation\n                    <i class=\"ph ph-arrow-right text-lg\" data-kid=\"1-8-1-2-4-1\" data-name=\"right arrow icon\">\n                    </i>\n                </a>\n            </div>\n        </div>\n    </section>\n    <!-- Footer (Obsidian Deep) -->\n    <footer class=\"bg-[#171717] text-white pt-40 pb-16\" data-kid=\"1-9\" data-name=\"footer\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12\" data-kid=\"1-9-1\" data-name=\"footer inner container\">\n            <div class=\"grid grid-cols-1 md:grid-cols-12 gap-24 mb-40\" data-kid=\"1-9-1-1\" data-name=\"footer grid\">\n                <div class=\"md:col-span-5\" data-kid=\"1-9-1-1-1\" data-name=\"footer brand block\">\n                    <div class=\"flex items-center gap-4 mb-14\" data-kid=\"1-9-1-1-1-1\" data-name=\"footer brand logo container\">\n                        <span class=\"block w-3 h-3 bg-[#C8A46A]\" data-kid=\"1-9-1-1-1-1-1\" data-name=\"brand square\">\n                        </span>\n                        <span class=\"font-serif text-4xl tracking-tight\" data-kid=\"1-9-1-1-1-1-2\" data-name=\"brand text\">\n                            NextGen\n                            <span class=\"italic text-[#C8A46A]\" data-kid=\"1-9-1-1-1-1-2-1\" data-name=\"brand accent text\">\n                                Interiors\n                            </span>\n                        </span>\n                    </div>\n                    <p class=\"font-serif text-4xl md:text-5xl font-light leading-snug max-w-lg text-white/90\" data-kid=\"1-9-1-1-1-2\" data-name=\"footer description\">\n                        Quietly considered interiors for residences and workplaces across India.\n                    </p>\n                    <div class=\"mt-16 flex gap-10\" data-kid=\"1-9-1-1-1-3\" data-name=\"social media links block\">\n                        <a class=\"text-white/30 hover:text-[#C8A46A] transition-colors\" data-kid=\"1-9-1-1-1-3-1\" data-name=\"instagram link\" href=\"#\">\n                            <i class=\"ph ph-instagram-logo text-3xl\" data-kid=\"1-9-1-1-1-3-1-1\" data-name=\"instagram icon\">\n                            </i>\n                        </a>\n                        <a class=\"text-white/30 hover:text-[#C8A46A] transition-colors\" data-kid=\"1-9-1-1-1-3-2\" data-name=\"linkedin link\" href=\"#\">\n                            <i class=\"ph ph-linkedin-logo text-3xl\" data-kid=\"1-9-1-1-1-3-2-1\" data-name=\"linkedin icon\">\n                            </i>\n                        </a>\n                    </div>\n                </div>\n                <div class=\"md:col-span-3 md:col-start-7\" data-kid=\"1-9-1-1-2\" data-name=\"footer navigation list container\">\n                    <h6 class=\"text-[11px] tracking-[0.3em] uppercase text-[#C8A46A] mb-10 font-bold\" data-kid=\"1-9-1-1-2-1\" data-name=\"footer links title\">\n                        Studio\n                    </h6>\n                    <ul class=\"space-y-6 text-white/50 text-[13px] tracking-widest uppercase font-medium\" data-kid=\"1-9-1-1-2-2\" data-name=\"footer links list\">\n                        <li data-kid=\"1-9-1-1-2-2-1\" data-name=\"nav link item\">\n                            <a class=\"hover:text-white transition-colors\" data-kid=\"1-9-1-1-2-2-1-1\" data-name=\"nav link\" href=\"#\">\n                                About\n                            </a>\n                        </li>\n                        <li data-kid=\"1-9-1-1-2-2-2\" data-name=\"nav link item\">\n                            <a class=\"hover:text-white transition-colors\" data-kid=\"1-9-1-1-2-2-2-1\" data-name=\"nav link\" href=\"#\">\n                                Process\n                            </a>\n                        </li>\n                        <li data-kid=\"1-9-1-1-2-2-3\" data-name=\"nav link item\">\n                            <a class=\"hover:text-white transition-colors\" data-kid=\"1-9-1-1-2-2-3-1\" data-name=\"nav link\" href=\"#\">\n                                Portfolio\n                            </a>\n                        </li>\n                        <li data-kid=\"1-9-1-1-2-2-4\" data-name=\"nav link item\">\n                            <a class=\"hover:text-white transition-colors\" data-kid=\"1-9-1-1-2-2-4-1\" data-name=\"nav link\" href=\"#\">\n                                Journal\n                            </a>\n                        </li>\n                        <li data-kid=\"1-9-1-1-2-2-5\" data-name=\"nav link item\">\n                            <a class=\"hover:text-white transition-colors\" data-kid=\"1-9-1-1-2-2-5-1\" data-name=\"nav link\" href=\"#\">\n                                Contact\n                            </a>\n                        </li>\n                    </ul>\n                </div>\n                <div class=\"md:col-span-3\" data-kid=\"1-9-1-1-3\" data-name=\"footer contact info block\">\n                    <h6 class=\"text-[11px] tracking-[0.3em] uppercase text-[#C8A46A] mb-10 font-bold\" data-kid=\"1-9-1-1-3-1\" data-name=\"contact title\">\n                        Connect\n                    </h6>\n                    <address class=\"not-italic text-white/50 text-base leading-relaxed mb-10 font-light\" data-kid=\"1-9-1-1-3-2\" data-name=\"address\">\n                        Suite 402, High Street\n                        <br data-kid=\"1-9-1-1-3-2-1\" data-name=\"address line break\"/>\n                        Indiranagar, Bengaluru 560038\n                    </address>\n                    <div class=\"text-[11px] tracking-[0.3em] uppercase text-[#C8A46A] mb-4 font-bold\" data-kid=\"1-9-1-1-3-3\" data-name=\"email label\">\n                        Contact\n                    </div>\n                    <a class=\"block text-white/70 hover:text-[#C8A46A] transition-colors text-lg font-serif italic\" data-kid=\"1-9-1-1-3-4\" data-name=\"email address link\" href=\"mailto:hello@nextgeninteriors.com\">\n                        hello@nextgeninteriors.com\n                    </a>\n                </div>\n            </div>\n            <div class=\"flex flex-col md:flex-row justify-between items-center pt-16 border-t border-white/5 gap-8\" data-kid=\"1-9-1-2\" data-name=\"footer bottom row\">\n                <span class=\"text-[11px] tracking-[0.3em] uppercase text-white/20\" data-kid=\"1-9-1-2-1\" data-name=\"copyright text\">\n                    © 2024 NextGen Interiors. All rights reserved.\n                </span>\n                <span class=\"text-[11px] tracking-[0.3em] uppercase text-white/20 font-medium\" data-kid=\"1-9-1-2-2\" data-name=\"location disclaimer\">\n                    Crafted in Bengaluru · Working pan-India\n                </span>\n            </div>\n        </div>\n    </footer>\n</div>\n<script src=\"https://unpkg.com/@phosphor-icons/web\">\n</script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js\">\n</script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js\">\n</script>\n<script>\n    gsap.registerPlugin(ScrollTrigger);\n\n  // Navbar Transition\n  ScrollTrigger.create({\n    start: \"top -50\",\n    onEnter: () => {\n      gsap.to(\"#navbar\", { backgroundColor: \"rgba(255, 255, 255, 0.9)\", backdropFilter: \"blur(16px)\", borderBottom: \"1px solid #E7E2DA\", padding: \"16px 0\", duration: 0.6, ease: \"power2.out\" });\n      gsap.to(\"#logo-text\", { color: \"#1E1E1E\", duration: 0.4 });\n      gsap.to([\"#nav-link-1\", \"#nav-link-2\", \"#nav-link-3\", \"#nav-link-4\", \"#nav-link-5\"], { color: \"#707070\", duration: 0.4 });\n      gsap.to(\"#nav-cta\", { backgroundColor: \"#171717\", color: \"#FFFFFF\", duration: 0.4 });\n    },\n    onLeaveBack: () => {\n      gsap.to(\"#navbar\", { backgroundColor: \"transparent\", backdropFilter: \"blur(0px)\", borderBottom: \"1px solid transparent\", padding: \"24px 0\", duration: 0.6, ease: \"power2.out\" });\n      gsap.to(\"#logo-text\", { color: \"#FFFFFF\", duration: 0.4 });\n      gsap.to([\"#nav-link-1\", \"#nav-link-2\", \"#nav-link-3\", \"#nav-link-4\", \"#nav-link-5\"], { color: \"#FFFFFF\", duration: 0.4 });\n      gsap.to(\"#nav-cta\", { backgroundColor: \"#FFFFFF\", color: \"#171717\", duration: 0.4 });\n    }\n  });\n\n  // Hero Reveal Animations\n  gsap.to(\".reveal-item\", {\n    opacity: 1,\n    y: 0,\n    stagger: 0.2,\n    duration: 1.4,\n    ease: \"power3.out\",\n    delay: 0.6\n  });\n\n  // Scroll Reveal for each section\n  const revealElements = gsap.utils.toArray('section h2, section p, section .group, section .reveal-block');\n  revealElements.forEach(el => {\n    gsap.from(el, {\n      y: 40,\n      opacity: 0,\n      duration: 1.2,\n      ease: \"power2.out\",\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 85%\",\n        toggleActions: \"play none none none\"\n      }\n    });\n  });\n\n  // Parallax effect for Hero Image\n  gsap.to(\"section img\", {\n    yPercent: 20,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \"section\",\n      start: \"top top\",\n      end: \"bottom top\",\n      scrub: true\n    }\n  });\n</script>\n",
      "comments": [],
      "created": "2026-07-20T11:08:51.374624+00:00",
      "modified": "2026-07-20T11:10:16.091053+00:00",
      "id": "var_ba4a3f6890b5"
    },
    "var_3d94bbce06c8": {
      "type": "variant",
      "label": "About Page - Redesign (The Tactile)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 6160,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap');\n\n  :root {\n    --bg-light: #F6F4F1;\n    --surface: #FFFFFF;\n    --ink-primary: #1E1E1E;\n    --ink-secondary: #707070;\n    --border-stone: #E7E2DA;\n    --gold: #C8A46A;\n    --gold-hover: #D6B27A;\n    --dark-primary: #171717;\n    --dark-secondary: #262626;\n    --white: #FFFFFF;\n    --white-muted: rgba(255,255,255,0.75);\n  }\n\n  body {\n    margin: 0;\n    font-family: 'Inter', sans-serif;\n    background-color: var(--bg-light);\n    color: var(--ink-primary);\n  }\n\n  ::selection {\n    background-color: var(--gold);\n    color: white;\n  }\n\n  .font-serif {\n    font-family: 'Instrument Serif', serif;\n  }\n\n  .ngi-grain {\n    position: relative;\n  }\n  .ngi-grain::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    opacity: 0.03;\n    pointer-events: none;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3%3Ffilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n    z-index: 1;\n  }\n\n  .glass-nav {\n    background: rgba(255, 255, 255, 0.88);\n    backdrop-filter: blur(12px);\n    border-bottom: 1px solid var(--border-stone);\n  }\n\n  .shadow-tactile {\n    box-shadow: 0 18px 50px rgba(23, 23, 23, 0.06);\n    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);\n  }\n  .shadow-tactile:hover {\n    box-shadow: 0 30px 70px -15px rgba(23, 23, 23, 0.12);\n    transform: translateY(-4px);\n  }\n</style>\n<div class=\"min-h-screen\" data-kid=\"1\" data-name=\"page layout container\">\n    <!-- Navigation (Simulated Scrolled State) -->\n    <header class=\"fixed top-0 left-0 right-0 z-50 glass-nav\" data-kid=\"1-1\" data-name=\"navigation header\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 flex items-center justify-between py-5 md:py-6\" data-kid=\"1-1-1\" data-name=\"navigation inner container\">\n            <a class=\"flex items-center gap-3 group\" data-kid=\"1-1-1-1\" data-name=\"brand logo and name\" href=\"#\">\n                <span class=\"block w-2 h-2 bg-[var(--gold)]\" data-kid=\"1-1-1-1-1\" data-name=\"brand identity dot icon\">\n                </span>\n                <span class=\"font-serif text-xl md:text-2xl tracking-tight text-[var(--ink-primary)]\" data-kid=\"1-1-1-1-2\" data-name=\"brand name text\">\n                    NextGen\n                    <span class=\"italic font-normal text-[var(--ink-secondary)]\" data-kid=\"1-1-1-1-2-1\" data-name=\"brand name suffix text\">\n                        Interiors\n                    </span>\n                </span>\n            </a>\n            <nav class=\"hidden lg:flex items-center gap-10\" data-kid=\"1-1-1-2\" data-name=\"navigation menu\">\n                <a class=\"text-[13px] tracking-wider uppercase text-[var(--ink-primary)] hover:text-[var(--gold)] transition-colors\" data-kid=\"1-1-1-2-1\" data-name=\"home link\" href=\"#\">\n                    Home\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[var(--ink-primary)] border-b border-[var(--ink-primary)]\" data-kid=\"1-1-1-2-2\" data-name=\"about link\" href=\"#\">\n                    About\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[var(--ink-secondary)] hover:text-[var(--gold)] transition-colors\" data-kid=\"1-1-1-2-3\" data-name=\"services link\" href=\"#\">\n                    Services\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[var(--ink-secondary)] hover:text-[var(--gold)] transition-colors\" data-kid=\"1-1-1-2-4\" data-name=\"portfolio link\" href=\"#\">\n                    Portfolio\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[var(--ink-secondary)] hover:text-[var(--gold)] transition-colors\" data-kid=\"1-1-1-2-5\" data-name=\"process link\" href=\"#\">\n                    Process\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[var(--ink-secondary)] hover:text-[var(--gold)] transition-colors\" data-kid=\"1-1-1-2-6\" data-name=\"journal link\" href=\"#\">\n                    Journal\n                </a>\n                <a class=\"text-[13px] tracking-wider uppercase text-[var(--ink-secondary)] hover:text-[var(--gold)] transition-colors\" data-kid=\"1-1-1-2-7\" data-name=\"contact link\" href=\"#\">\n                    Contact\n                </a>\n            </nav>\n            <a class=\"hidden md:inline-flex items-center bg-[var(--dark-primary)] text-white px-6 py-3 text-[11px] tracking-[0.22em] uppercase hover:bg-[var(--gold)] transition-colors duration-300\" data-kid=\"1-1-1-3\" data-name=\"book consultation button\" href=\"#\">\n                Book Consultation\n            </a>\n        </div>\n    </header>\n    <main class=\"pt-32\" data-kid=\"1-2\" data-name=\"main content area\">\n        <!-- Hero Section -->\n        <section class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24\" data-kid=\"1-2-1\" data-name=\"hero section\">\n            <div class=\"mb-6 flex items-center gap-4\" data-kid=\"1-2-1-1\" data-name=\"hero pre-headline container\">\n                <span class=\"w-12 h-px bg-[var(--gold)]\" data-kid=\"1-2-1-1-1\" data-name=\"horizontal accent line\">\n                </span>\n                <span class=\"text-[11px] tracking-[0.22em] uppercase text-[var(--gold)] font-medium\" data-kid=\"1-2-1-1-2\" data-name=\"hero pre-headline label\">\n                    The Studio\n                </span>\n            </div>\n            <h1 class=\"font-serif text-5xl md:text-7xl lg:text-8xl font-light tracking-tighter leading-[1.02] max-w-5xl\" data-kid=\"1-2-1-2\" data-name=\"hero main headline\">\n                A small studio in Bengaluru, working\n                <em class=\"text-[var(--ink-secondary)]\" data-kid=\"1-2-1-2-1\" data-name=\"emphasized headline word\">\n                    unhurriedly\n                </em>\n                , across India.\n            </h1>\n        </section>\n        <!-- Studio Intro -->\n        <section class=\"max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-12 gap-10 mb-24 md:mb-32\" data-kid=\"1-2-2\" data-name=\"studio intro section\">\n            <div class=\"md:col-span-7\" data-kid=\"1-2-2-1\" data-name=\"studio image container\">\n                <div class=\"aspect-[16/10] overflow-hidden rounded-sm grayscale hover:grayscale-0 transition-all duration-700\" data-kid=\"1-2-2-1-1\" data-name=\"studio image wrapper\">\n                    <img alt=\"Studio\" class=\"w-full h-full object-cover\" data-kid=\"1-2-2-1-1-1\" data-name=\"studio interior photograph\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/13201479/pexels-photo-13201479.jpeg\"/>\n                </div>\n            </div>\n            <div class=\"md:col-span-4 md:col-start-9 self-end\" data-kid=\"1-2-2-2\" data-name=\"studio description text container\">\n                <p class=\"text-lg md:text-xl leading-relaxed text-[var(--ink-primary)]/85\" data-kid=\"1-2-2-2-1\" data-name=\"first description paragraph\">\n                    NextGen Interiors is a thirteen-person practice founded in 2013. We work on residential and commercial interior architecture — homes, offices, restaurants — for clients who care about how a room feels at 7am.\n                </p>\n                <p class=\"mt-6 text-lg md:text-xl leading-relaxed text-[var(--ink-primary)]/85\" data-kid=\"1-2-2-2-2\" data-name=\"second description paragraph\">\n                    We are not stylists. We are interior architects, which is to say we draw every joint, specify every finish, and stand on site every week until the work is finished.\n                </p>\n            </div>\n        </section>\n        <!-- Principles Section -->\n        <section class=\"bg-white/40 border-y border-[var(--border-stone)]\" data-kid=\"1-2-3\" data-name=\"principles section\">\n            <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-24 lg:py-32\" data-kid=\"1-2-3-1\" data-name=\"principles content wrapper\">\n                <div class=\"mb-16 max-w-2xl\" data-kid=\"1-2-3-1-1\" data-name=\"principles header group\">\n                    <div class=\"mb-4 flex items-center gap-4\" data-kid=\"1-2-3-1-1-1\" data-name=\"principles label container\">\n                        <span class=\"w-12 h-px bg-[var(--gold)]\" data-kid=\"1-2-3-1-1-1-1\" data-name=\"horizontal accent line\">\n                        </span>\n                        <span class=\"text-[11px] tracking-[0.22em] uppercase text-[var(--gold)] font-medium\" data-kid=\"1-2-3-1-1-1-2\" data-name=\"principles label\">\n                            Four principles\n                        </span>\n                    </div>\n                    <h2 class=\"font-serif text-4xl md:text-5xl lg:text-6xl font-light tracking-tight leading-tight\" data-kid=\"1-2-3-1-1-2\" data-name=\"principles section title\">\n                        What we believe.\n                    </h2>\n                </div>\n                <div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24\" data-kid=\"1-2-3-1-2\" data-name=\"principles grid\">\n                    <div class=\"border-t border-[var(--border-stone)] pt-8\" data-kid=\"1-2-3-1-2-1\" data-name=\"first principle card\">\n                        <div class=\"font-serif text-5xl text-[var(--gold)] font-light mb-4 italic\" data-kid=\"1-2-3-1-2-1-1\" data-name=\"principle number\">\n                            01\n                        </div>\n                        <h3 class=\"font-serif text-3xl font-light mb-4\" data-kid=\"1-2-3-1-2-1-2\" data-name=\"principle title\">\n                            Restraint\n                        </h3>\n                        <p class=\"text-lg text-[var(--ink-primary)]/75 leading-relaxed\" data-kid=\"1-2-3-1-2-1-3\" data-name=\"principle description\">\n                            We subtract until what remains is irreducible. Restraint is the editorial discipline behind every room we have built.\n                        </p>\n                    </div>\n                    <div class=\"border-t border-[var(--border-stone)] pt-8\" data-kid=\"1-2-3-1-2-2\" data-name=\"second principle card\">\n                        <div class=\"font-serif text-5xl text-[var(--gold)] font-light mb-4 italic\" data-kid=\"1-2-3-1-2-2-1\" data-name=\"principle number\">\n                            02\n                        </div>\n                        <h3 class=\"font-serif text-3xl font-light mb-4\" data-kid=\"1-2-3-1-2-2-2\" data-name=\"principle title\">\n                            Material literacy\n                        </h3>\n                        <p class=\"text-lg text-[var(--ink-primary)]/75 leading-relaxed\" data-kid=\"1-2-3-1-2-2-3\" data-name=\"principle description\">\n                            We know our way around stone, wood, plaster, fabric, brass and the people who work them. Specification is not a catalogue choice.\n                        </p>\n                    </div>\n                    <div class=\"border-t border-[var(--border-stone)] pt-8\" data-kid=\"1-2-3-1-2-3\" data-name=\"third principle card\">\n                        <div class=\"font-serif text-5xl text-[var(--gold)] font-light mb-4 italic\" data-kid=\"1-2-3-1-2-3-1\" data-name=\"principle number\">\n                            03\n                        </div>\n                        <h3 class=\"font-serif text-3xl font-light mb-4\" data-kid=\"1-2-3-1-2-3-2\" data-name=\"principle title\">\n                            Light first\n                        </h3>\n                        <p class=\"text-lg text-[var(--ink-primary)]/75 leading-relaxed\" data-kid=\"1-2-3-1-2-3-3\" data-name=\"principle description\">\n                            We brief a lighting plan before we draw a furniture plan. Light is the room. Furniture is its punctuation.\n                        </p>\n                    </div>\n                    <div class=\"border-t border-[var(--border-stone)] pt-8\" data-kid=\"1-2-3-1-2-4\" data-name=\"fourth principle card\">\n                        <div class=\"font-serif text-5xl text-[var(--gold)] font-light mb-4 italic\" data-kid=\"1-2-3-1-2-4-1\" data-name=\"principle number\">\n                            04\n                        </div>\n                        <h3 class=\"font-serif text-3xl font-light mb-4\" data-kid=\"1-2-3-1-2-4-2\" data-name=\"principle title\">\n                            Time as a tool\n                        </h3>\n                        <p class=\"text-lg text-[var(--ink-primary)]/75 leading-relaxed\" data-kid=\"1-2-3-1-2-4-3\" data-name=\"principle description\">\n                            Good interiors are unhurried. We will tell you when the schedule is wrong, and we will protect the timeline once we have signed it.\n                        </p>\n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- Team Section -->\n        <section class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-24 lg:py-32\" data-kid=\"1-2-4\" data-name=\"team section\">\n            <div class=\"mb-12\" data-kid=\"1-2-4-1\" data-name=\"team header group\">\n                <div class=\"mb-4 flex items-center gap-4\" data-kid=\"1-2-4-1-1\" data-name=\"team label container\">\n                    <span class=\"w-12 h-px bg-[var(--gold)]\" data-kid=\"1-2-4-1-1-1\" data-name=\"horizontal accent line\">\n                    </span>\n                    <span class=\"text-[11px] tracking-[0.22em] uppercase text-[var(--gold)] font-medium\" data-kid=\"1-2-4-1-1-2\" data-name=\"team label\">\n                        The People\n                    </span>\n                </div>\n                <h2 class=\"font-serif text-4xl md:text-5xl lg:text-6xl font-light tracking-tight\" data-kid=\"1-2-4-1-2\" data-name=\"team section title\">\n                    A studio of thirteen.\n                </h2>\n            </div>\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12\" data-kid=\"1-2-4-2\" data-name=\"team member grid\">\n                <div class=\"group\" data-kid=\"1-2-4-2-1\" data-name=\"team member card\">\n                    <div class=\"aspect-[3/4] overflow-hidden rounded-[22px] shadow-tactile bg-[var(--surface)] p-2\" data-kid=\"1-2-4-2-1-1\" data-name=\"team member image wrapper\">\n                        <img alt=\"Aanya Rao\" class=\"w-full h-full object-cover rounded-[18px] grayscale transition-all duration-500 group-hover:grayscale-0\" data-kid=\"1-2-4-2-1-1-1\" data-name=\"team member photograph\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600\"/>\n                    </div>\n                    <h3 class=\"mt-6 font-serif text-2xl font-light\" data-kid=\"1-2-4-2-1-2\" data-name=\"team member name\">\n                        Aanya Rao\n                    </h3>\n                    <div class=\"text-[10px] tracking-[0.2em] uppercase text-[var(--ink-secondary)] mt-1\" data-kid=\"1-2-4-2-1-3\" data-name=\"team member role\">\n                        Founder & Principal Architect\n                    </div>\n                </div>\n                <div class=\"group\" data-kid=\"1-2-4-2-2\" data-name=\"team member card\">\n                    <div class=\"aspect-[3/4] overflow-hidden rounded-[22px] shadow-tactile bg-[var(--surface)] p-2\" data-kid=\"1-2-4-2-2-1\" data-name=\"team member image wrapper\">\n                        <img alt=\"Rohan Iyer\" class=\"w-full h-full object-cover rounded-[18px] grayscale transition-all duration-500 group-hover:grayscale-0\" data-kid=\"1-2-4-2-2-1-1\" data-name=\"team member photograph\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600\"/>\n                    </div>\n                    <h3 class=\"mt-6 font-serif text-2xl font-light\" data-kid=\"1-2-4-2-2-2\" data-name=\"team member name\">\n                        Rohan Iyer\n                    </h3>\n                    <div class=\"text-[10px] tracking-[0.2em] uppercase text-[var(--ink-secondary)] mt-1\" data-kid=\"1-2-4-2-2-3\" data-name=\"team member role\">\n                        Design Director\n                    </div>\n                </div>\n                <div class=\"group\" data-kid=\"1-2-4-2-3\" data-name=\"team member card\">\n                    <div class=\"aspect-[3/4] overflow-hidden rounded-[22px] shadow-tactile bg-[var(--surface)] p-2\" data-kid=\"1-2-4-2-3-1\" data-name=\"team member image wrapper\">\n                        <img alt=\"Maya Bhattacharya\" class=\"w-full h-full object-cover rounded-[18px] grayscale transition-all duration-500 group-hover:grayscale-0\" data-kid=\"1-2-4-2-3-1-1\" data-name=\"team member photograph\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=600\"/>\n                    </div>\n                    <h3 class=\"mt-6 font-serif text-2xl font-light\" data-kid=\"1-2-4-2-3-2\" data-name=\"team member name\">\n                        Maya Bhattacharya\n                    </h3>\n                    <div class=\"text-[10px] tracking-[0.2em] uppercase text-[var(--ink-secondary)] mt-1\" data-kid=\"1-2-4-2-3-3\" data-name=\"team member role\">\n                        Head of Materials\n                    </div>\n                </div>\n                <div class=\"group\" data-kid=\"1-2-4-2-4\" data-name=\"team member card\">\n                    <div class=\"aspect-[3/4] overflow-hidden rounded-[22px] shadow-tactile bg-[var(--surface)] p-2\" data-kid=\"1-2-4-2-4-1\" data-name=\"team member image wrapper\">\n                        <img alt=\"Karan Pillai\" class=\"w-full h-full object-cover rounded-[18px] grayscale transition-all duration-500 group-hover:grayscale-0\" data-kid=\"1-2-4-2-4-1-1\" data-name=\"team member photograph\" decoding=\"async\" loading=\"lazy\" src=\"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=600\"/>\n                    </div>\n                    <h3 class=\"mt-6 font-serif text-2xl font-light\" data-kid=\"1-2-4-2-4-2\" data-name=\"team member name\">\n                        Karan Pillai\n                    </h3>\n                    <div class=\"text-[10px] tracking-[0.2em] uppercase text-[var(--ink-secondary)] mt-1\" data-kid=\"1-2-4-2-4-3\" data-name=\"team member role\">\n                        Studio Manager\n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- Stats Section -->\n        <section class=\"bg-[var(--dark-primary)] text-white ngi-grain overflow-hidden\" data-kid=\"1-2-5\" data-name=\"stats section\">\n            <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-24 lg:py-32 grid grid-cols-2 md:grid-cols-4 gap-12 relative z-10\" data-kid=\"1-2-5-1\" data-name=\"stats grid\">\n                <div data-kid=\"1-2-5-1-1\" data-name=\"stat card\">\n                    <div class=\"font-serif text-6xl md:text-7xl text-[var(--gold)] font-light leading-none\" data-kid=\"1-2-5-1-1-1\" data-name=\"stat value\">\n                        240\n                        <span class=\"text-3xl align-top\" data-kid=\"1-2-5-1-1-1-1\" data-name=\"stat suffix\">\n                            +\n                        </span>\n                    </div>\n                    <div class=\"text-[10px] tracking-[0.22em] uppercase text-white/50 mt-4\" data-kid=\"1-2-5-1-1-2\" data-name=\"stat label\">\n                        Projects Completed\n                    </div>\n                </div>\n                <div data-kid=\"1-2-5-1-2\" data-name=\"stat card\">\n                    <div class=\"font-serif text-6xl md:text-7xl text-[var(--gold)] font-light leading-none\" data-kid=\"1-2-5-1-2-1\" data-name=\"stat value\">\n                        12\n                    </div>\n                    <div class=\"text-[10px] tracking-[0.22em] uppercase text-white/50 mt-4\" data-kid=\"1-2-5-1-2-2\" data-name=\"stat label\">\n                        Years in Practice\n                    </div>\n                </div>\n                <div data-kid=\"1-2-5-1-3\" data-name=\"stat card\">\n                    <div class=\"font-serif text-6xl md:text-7xl text-[var(--gold)] font-light leading-none\" data-kid=\"1-2-5-1-3-1\" data-name=\"stat value\">\n                        14\n                    </div>\n                    <div class=\"text-[10px] tracking-[0.22em] uppercase text-white/50 mt-4\" data-kid=\"1-2-5-1-3-2\" data-name=\"stat label\">\n                        Cities Served\n                    </div>\n                </div>\n                <div data-kid=\"1-2-5-1-4\" data-name=\"stat card\">\n                    <div class=\"font-serif text-6xl md:text-7xl text-[var(--gold)] font-light leading-none\" data-kid=\"1-2-5-1-4-1\" data-name=\"stat value\">\n                        13\n                    </div>\n                    <div class=\"text-[10px] tracking-[0.22em] uppercase text-white/50 mt-4\" data-kid=\"1-2-5-1-4-2\" data-name=\"stat label\">\n                        Studio Team\n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- Final CTA -->\n        <section class=\"max-w-[1440px] mx-auto px-6 md:px-12 py-24 lg:py-40 text-center\" data-kid=\"1-2-6\" data-name=\"final call-to-action section\">\n            <div class=\"mb-6 inline-flex items-center gap-4\" data-kid=\"1-2-6-1\" data-name=\"cta header container\">\n                <span class=\"w-12 h-px bg-[var(--gold)]\" data-kid=\"1-2-6-1-1\" data-name=\"horizontal accent line\">\n                </span>\n                <span class=\"text-[11px] tracking-[0.22em] uppercase text-[var(--gold)] font-medium\" data-kid=\"1-2-6-1-2\" data-name=\"cta label\">\n                    Work with us\n                </span>\n                <span class=\"w-12 h-px bg-[var(--gold)]\" data-kid=\"1-2-6-1-3\" data-name=\"horizontal accent line\">\n                </span>\n            </div>\n            <h2 class=\"font-serif text-5xl md:text-7xl lg:text-8xl font-light tracking-tight leading-tight max-w-4xl mx-auto mb-12\" data-kid=\"1-2-6-2\" data-name=\"cta headline\">\n                Begin a conversation.\n            </h2>\n            <a class=\"inline-flex bg-[var(--dark-primary)] text-white hover:bg-[var(--gold)] hover:text-white px-12 py-6 text-[11px] tracking-[0.22em] uppercase transition-all duration-500 shadow-xl\" data-kid=\"1-2-6-3\" data-name=\"cta button\" href=\"#\">\n                Book a Consultation\n            </a>\n        </section>\n    </main>\n    <!-- Footer (Simulated) -->\n    <footer class=\"bg-[var(--dark-primary)] text-white py-12 border-t border-white/5\" data-kid=\"1-3\" data-name=\"footer section\">\n        <div class=\"max-w-[1440px] mx-auto px-6 md:px-12 flex flex-col md:flex-row justify-between items-center gap-6\" data-kid=\"1-3-1\" data-name=\"footer content container\">\n            <div class=\"flex items-center gap-3\" data-kid=\"1-3-1-1\" data-name=\"footer brand container\">\n                <span class=\"block w-2 h-2 bg-[var(--gold)]\" data-kid=\"1-3-1-1-1\" data-name=\"brand identity dot icon\">\n                </span>\n                <span class=\"font-serif text-xl tracking-tight text-white\" data-kid=\"1-3-1-1-2\" data-name=\"footer brand name\">\n                    NextGen Interiors\n                </span>\n            </div>\n            <div class=\"text-[11px] tracking-[0.22em] uppercase text-white/40\" data-kid=\"1-3-1-2\" data-name=\"copyright notice\">\n                © 2026 NextGen Interiors · Crafted in Bengaluru\n            </div>\n        </div>\n    </footer>\n</div>\n",
      "comments": [],
      "created": "2026-07-20T11:11:39.531678+00:00",
      "modified": "2026-07-20T11:12:07.558026+00:00",
      "id": "var_3d94bbce06c8"
    },
    "var_7d14fe31d2a1": {
      "type": "variant",
      "label": "About Page - Redesign (The Architectural)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 7700,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style>\n    @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital,wght@0,400;1,400&family=Inter:wght@300;400;500;600&display=swap');\n\n  :root {\n    --color-bg-light: #F6F4F1;\n    --color-surface: #FFFFFF;\n    --color-ink-primary: #1E1E1E;\n    --color-ink-secondary: #707070;\n    --color-border-stone: #E7E2DA;\n    --color-gold: #C8A46A;\n    --color-gold-hover: #D6B27A;\n    --color-dark-primary: #171717;\n    --color-dark-secondary: #262626;\n  }\n\n  ::selection {\n    background-color: var(--color-gold);\n    color: white;\n  }\n\n  .font-serif {\n    font-family: 'Instrument Serif', serif;\n  }\n\n  .font-sans {\n    font-family: 'Inter', sans-serif;\n  }\n\n  .ngi-grain {\n    position: relative;\n  }\n\n  .ngi-grain::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    opacity: 0.03;\n    pointer-events: none;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E\");\n  }\n\n  .ngi-rule {\n    display: inline-block;\n    width: 24px;\n    height: 1px;\n    background-color: currentColor;\n    margin-right: 12px;\n    vertical-align: middle;\n  }\n\n  .ngi-overline {\n    font-family: 'Inter', sans-serif;\n    font-size: 11px;\n    font-weight: 500;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n  }\n\n  .architectural-transition {\n    position: relative;\n    overflow: hidden;\n  }\n</style>\n<div class=\"font-sans text-[var(--color-ink-primary)] bg-[var(--color-bg-light)] min-h-screen selection:bg-[var(--color-gold)] selection:text-white\" data-kid=\"1\" data-name=\"page layout container\">\n    <!-- Studio Intro -->\n    <section class=\"max-w-[1280px] mx-auto px-6 md:px-12 pt-40 pb-16 md:pb-24\" data-kid=\"1-1\" data-name=\"studio intro section\">\n        <div class=\"opacity-0 translate-y-8 animate-[fadeIn_0.8s_ease-out_forwards]\" data-kid=\"1-1-1\" data-name=\"intro content wrapper\">\n            <div class=\"ngi-overline text-[var(--color-gold)] mb-6 flex items-center\" data-kid=\"1-1-1-1\" data-name=\"section overline with accent rule\">\n                <span class=\"ngi-rule\" data-kid=\"1-1-1-1-1\" data-name=\"horizontal accent rule\">\n                </span>\n                The Studio\n            </div>\n            <h1 class=\"font-serif text-6xl md:text-8xl font-light tracking-tighter leading-[0.95] max-w-5xl\" data-kid=\"1-1-1-2\" data-name=\"studio hero headline\">\n                A small studio in Bengaluru, working\n                <em class=\"text-[var(--color-ink-secondary)] italic\" data-kid=\"1-1-1-2-1\" data-name=\"italic emphasis text\">\n                    unhurriedly\n                </em>\n                , across India.\n            </h1>\n        </div>\n    </section>\n    <!-- Studio Image & Description -->\n    <section class=\"max-w-[1280px] mx-auto px-6 md:px-12 grid grid-cols-1 md:grid-cols-12 gap-10 mb-32 md:mb-48\" data-kid=\"1-2\" data-name=\"studio image and description section\">\n        <div class=\"md:col-span-7 overflow-hidden rounded-xs opacity-0 translate-y-8 animate-[fadeIn_0.8s_0.2s_ease-out_forwards]\" data-kid=\"1-2-1\" data-name=\"studio space image container\">\n            <img alt=\"Studio Space\" class=\"w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000 scale-100 hover:scale-105\" data-kid=\"1-2-1-1\" data-name=\"studio space image\" decoding=\"async\" loading=\"lazy\" src=\"https://images.pexels.com/photos/13201479/pexels-photo-13201479.jpeg?auto=format&w=1200&q=80&fit=crop\"/>\n        </div>\n        <div class=\"md:col-span-4 md:col-start-9 self-end opacity-0 translate-y-8 animate-[fadeIn_0.8s_0.4s_ease-out_forwards]\" data-kid=\"1-2-2\" data-name=\"studio description text container\">\n            <p class=\"text-lg md:text-xl leading-relaxed text-[var(--color-ink-primary)]/90 font-light\" data-kid=\"1-2-2-1\" data-name=\"primary studio description paragraph\">\n                NextGen Interiors is a thirteen-person practice founded in 2013. We work on residential and commercial interior architecture — homes, offices, restaurants — for clients who care about how a room feels at 7am.\n            </p>\n            <p class=\"mt-8 text-lg md:text-xl leading-relaxed text-[var(--color-ink-primary)]/90 font-light\" data-kid=\"1-2-2-2\" data-name=\"secondary studio description paragraph\">\n                We are not stylists. We are interior architects, which is to say we draw every joint, specify every finish, and stand on site every week until the work is finished.\n            </p>\n        </div>\n    </section>\n    <!-- Four Principles - ARCHITECTURAL DARK TRANSITION -->\n    <section class=\"bg-[var(--color-dark-primary)] text-white ngi-grain architectural-transition py-24 md:py-32\" data-kid=\"1-3\" data-name=\"four principles section\">\n        <div class=\"max-w-[1280px] mx-auto px-6 md:px-12\" data-kid=\"1-3-1\" data-name=\"principles content wrapper\">\n            <div class=\"mb-20 max-w-2xl\" data-kid=\"1-3-1-1\" data-name=\"principles header container\">\n                <div class=\"ngi-overline text-[var(--color-gold)] mb-6 flex items-center\" data-kid=\"1-3-1-1-1\" data-name=\"principles overline with accent rule\">\n                    <span class=\"ngi-rule\" data-kid=\"1-3-1-1-1-1\" data-name=\"horizontal accent rule\">\n                    </span>\n                    Four Principles\n                </div>\n                <h2 class=\"font-serif text-5xl md:text-7xl font-light tracking-tight leading-tight\" data-kid=\"1-3-1-1-2\" data-name=\"principles section title\">\n                    What we believe.\n                </h2>\n            </div>\n            <div class=\"grid grid-cols-1 md:grid-cols-2 gap-x-20 gap-y-16\" data-kid=\"1-3-1-2\" data-name=\"principles grid container\">\n                <!-- Principle 01 -->\n                <div class=\"border-t border-white/10 pt-8 group\" data-kid=\"1-3-1-2-1\" data-name=\"principle item 1\">\n                    <div class=\"font-serif text-6xl text-[var(--color-gold)] font-light mb-6 transition-transform group-hover:-translate-y-2 duration-500\" data-kid=\"1-3-1-2-1-1\" data-name=\"principle number 1\">\n                        01\n                    </div>\n                    <h3 class=\"font-serif text-3xl md:text-4xl font-light mb-4\" data-kid=\"1-3-1-2-1-2\" data-name=\"principle title 1\">\n                        Restraint\n                    </h3>\n                    <p class=\"text-white/70 text-lg leading-relaxed font-light max-w-md\" data-kid=\"1-3-1-2-1-3\" data-name=\"principle description 1\">\n                        We subtract until what remains is irreducible. Restraint is the editorial discipline behind every room we have built.\n                    </p>\n                </div>\n                <!-- Principle 02 -->\n                <div class=\"border-t border-white/10 pt-8 group\" data-kid=\"1-3-1-2-2\" data-name=\"principle item 2\">\n                    <div class=\"font-serif text-6xl text-[var(--color-gold)] font-light mb-6 transition-transform group-hover:-translate-y-2 duration-500\" data-kid=\"1-3-1-2-2-1\" data-name=\"principle number 2\">\n                        02\n                    </div>\n                    <h3 class=\"font-serif text-3xl md:text-4xl font-light mb-4\" data-kid=\"1-3-1-2-2-2\" data-name=\"principle title 2\">\n                        Material literacy\n                    </h3>\n                    <p class=\"text-white/70 text-lg leading-relaxed font-light max-w-md\" data-kid=\"1-3-1-2-2-3\" data-name=\"principle description 2\">\n                        We know our way around stone, wood, plaster, fabric, brass and the people who work them. Specification is not a catalogue choice.\n                    </p>\n                </div>\n                <!-- Principle 03 -->\n                <div class=\"border-t border-white/10 pt-8 group\" data-kid=\"1-3-1-2-3\" data-name=\"principle item 3\">\n                    <div class=\"font-serif text-6xl text-[var(--color-gold)] font-light mb-6 transition-transform group-hover:-translate-y-2 duration-500\" data-kid=\"1-3-1-2-3-1\" data-name=\"principle number 3\">\n                        03\n                    </div>\n                    <h3 class=\"font-serif text-3xl md:text-4xl font-light mb-4\" data-kid=\"1-3-1-2-3-2\" data-name=\"principle title 3\">\n                        Light first\n                    </h3>\n                    <p class=\"text-white/70 text-lg leading-relaxed font-light max-w-md\" data-kid=\"1-3-1-2-3-3\" data-name=\"principle description 3\">\n                        We brief a lighting plan before we draw a furniture plan. Light is the room. Furniture is its punctuation.\n                    </p>\n                </div>\n                <!-- Principle 04 -->\n                <div class=\"border-t border-white/10 pt-8 group\" data-kid=\"1-3-1-2-4\" data-name=\"principle item 4\">\n                    <div class=\"font-serif text-6xl text-[var(--color-gold)] font-light mb-6 transition-transform group-hover:-translate-y-2 duration-500\" data-kid=\"1-3-1-2-4-1\" data-name=\"principle number 4\">\n                        04\n                    </div>\n                    <h3 class=\"font-serif text-3xl md:text-4xl font-light mb-4\" data-kid=\"1-3-1-2-4-2\" data-name=\"principle title 4\">\n                        Time as a tool\n                    </h3>\n                    <p class=\"text-white/70 text-lg leading-relaxed font-light max-w-md\" data-kid=\"1-3-1-2-4-3\" data-name=\"principle description 4\">\n                        Good interiors are unhurried. We will tell you when the schedule is wrong, and we will protect the timeline once we have signed it.\n                    </p>\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- The People -->\n    <section class=\"max-w-[1280px] mx-auto px-6 md:px-12 py-32 md:py-48\" data-kid=\"1-4\" data-name=\"people section\">\n        <div class=\"mb-16\" data-kid=\"1-4-1\" data-name=\"people section header container\">\n            <div class=\"ngi-overline text-[var(--color-gold)] mb-6 flex items-center\" data-kid=\"1-4-1-1\" data-name=\"people section overline\">\n                <span class=\"ngi-rule\" data-kid=\"1-4-1-1-1\" data-name=\"horizontal accent rule\">\n                </span>\n                The People\n            </div>\n            <h2 class=\"font-serif text-5xl md:text-7xl font-light tracking-tight\" data-kid=\"1-4-1-2\" data-name=\"people section title\">\n                A studio of thirteen.\n            </h2>\n        </div>\n        <div class=\"grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-12\" data-kid=\"1-4-2\" data-name=\"people grid container\">\n            <div class=\"group\" data-kid=\"1-4-2-1\" data-name=\"team member card 1\">\n                <div class=\"aspect-[3/4] overflow-hidden bg-[var(--color-border-stone)] mb-6\" data-kid=\"1-4-2-1-1\" data-name=\"team member image container\">\n                    <img alt=\"Aanya Rao\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0\" data-kid=\"1-4-2-1-1-1\" data-name=\"team member image\" src=\"https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=800&q=80&fit=crop\"/>\n                </div>\n                <h3 class=\"font-serif text-2xl font-light\" data-kid=\"1-4-2-1-2\" data-name=\"team member name 1\">\n                    Aanya Rao\n                </h3>\n                <div class=\"text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-secondary)] mt-2\" data-kid=\"1-4-2-1-3\" data-name=\"team member role 1\">\n                    Founder & Principal Architect\n                </div>\n            </div>\n            <div class=\"group\" data-kid=\"1-4-2-2\" data-name=\"team member card 2\">\n                <div class=\"aspect-[3/4] overflow-hidden bg-[var(--color-border-stone)] mb-6\" data-kid=\"1-4-2-2-1\" data-name=\"team member image container\">\n                    <img alt=\"Rohan Iyer\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0\" data-kid=\"1-4-2-2-1-1\" data-name=\"team member image\" src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&q=80&fit=crop\"/>\n                </div>\n                <h3 class=\"font-serif text-2xl font-light\" data-kid=\"1-4-2-2-2\" data-name=\"team member name 2\">\n                    Rohan Iyer\n                </h3>\n                <div class=\"text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-secondary)] mt-2\" data-kid=\"1-4-2-2-3\" data-name=\"team member role 2\">\n                    Design Director\n                </div>\n            </div>\n            <div class=\"group\" data-kid=\"1-4-2-3\" data-name=\"team member card 3\">\n                <div class=\"aspect-[3/4] overflow-hidden bg-[var(--color-border-stone)] mb-6\" data-kid=\"1-4-2-3-1\" data-name=\"team member image container\">\n                    <img alt=\"Maya Bhattacharya\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0\" data-kid=\"1-4-2-3-1-1\" data-name=\"team member image\" src=\"https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=800&q=80&fit=crop\"/>\n                </div>\n                <h3 class=\"font-serif text-2xl font-light\" data-kid=\"1-4-2-3-2\" data-name=\"team member name 3\">\n                    Maya Bhattacharya\n                </h3>\n                <div class=\"text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-secondary)] mt-2\" data-kid=\"1-4-2-3-3\" data-name=\"team member role 3\">\n                    Head of Materials\n                </div>\n            </div>\n            <div class=\"group\" data-kid=\"1-4-2-4\" data-name=\"team member card 4\">\n                <div class=\"aspect-[3/4] overflow-hidden bg-[var(--color-border-stone)] mb-6\" data-kid=\"1-4-2-4-1\" data-name=\"team member image container\">\n                    <img alt=\"Karan Pillai\" class=\"w-full h-full object-cover grayscale transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0\" data-kid=\"1-4-2-4-1-1\" data-name=\"team member image\" src=\"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=800&q=80&fit=crop\"/>\n                </div>\n                <h3 class=\"font-serif text-2xl font-light\" data-kid=\"1-4-2-4-2\" data-name=\"team member name 4\">\n                    Karan Pillai\n                </h3>\n                <div class=\"text-[10px] tracking-[0.2em] uppercase text-[var(--color-ink-secondary)] mt-2\" data-kid=\"1-4-2-4-3\" data-name=\"team member role 4\">\n                    Studio Manager\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Statistics - ARCHITECTURAL DARK -->\n    <section class=\"bg-[var(--color-dark-primary)] text-white ngi-grain py-32 border-y border-white/5\" data-kid=\"1-5\" data-name=\"statistics section\">\n        <div class=\"max-w-[1280px] mx-auto px-6 md:px-12 grid grid-cols-2 md:grid-cols-4 gap-12 text-center md:text-left\" data-kid=\"1-5-1\" data-name=\"statistics grid container\">\n            <div data-kid=\"1-5-1-1\" data-name=\"stat item 1\">\n                <div class=\"font-serif text-6xl md:text-7xl text-[var(--color-gold)] mb-4\" data-kid=\"1-5-1-1-1\" data-name=\"stat value 1\">\n                    240\n                    <span class=\"text-4xl align-top\" data-kid=\"1-5-1-1-1-1\" data-name=\"stat plus icon\">\n                        +\n                    </span>\n                </div>\n                <div class=\"text-[10px] tracking-[0.3em] uppercase text-white/50\" data-kid=\"1-5-1-1-2\" data-name=\"stat label 1\">\n                    Projects Completed\n                </div>\n            </div>\n            <div data-kid=\"1-5-1-2\" data-name=\"stat item 2\">\n                <div class=\"font-serif text-6xl md:text-7xl text-[var(--color-gold)] mb-4\" data-kid=\"1-5-1-2-1\" data-name=\"stat value 2\">\n                    12\n                </div>\n                <div class=\"text-[10px] tracking-[0.3em] uppercase text-white/50\" data-kid=\"1-5-1-2-2\" data-name=\"stat label 2\">\n                    Years of Practice\n                </div>\n            </div>\n            <div data-kid=\"1-5-1-3\" data-name=\"stat item 3\">\n                <div class=\"font-serif text-6xl md:text-7xl text-[var(--color-gold)] mb-4\" data-kid=\"1-5-1-3-1\" data-name=\"stat value 3\">\n                    14\n                </div>\n                <div class=\"text-[10px] tracking-[0.3em] uppercase text-white/50\" data-kid=\"1-5-1-3-2\" data-name=\"stat label 3\">\n                    Cities Across India\n                </div>\n            </div>\n            <div data-kid=\"1-5-1-4\" data-name=\"stat item 4\">\n                <div class=\"font-serif text-6xl md:text-7xl text-[var(--color-gold)] mb-4\" data-kid=\"1-5-1-4-1\" data-name=\"stat value 4\">\n                    13\n                </div>\n                <div class=\"text-[10px] tracking-[0.3em] uppercase text-white/50\" data-kid=\"1-5-1-4-2\" data-name=\"stat label 4\">\n                    Dedicated People\n                </div>\n            </div>\n        </div>\n    </section>\n    <!-- Final CTA -->\n    <section class=\"max-w-[1280px] mx-auto px-6 md:px-12 py-32 md:py-48 text-center\" data-kid=\"1-6\" data-name=\"final call-to-action section\">\n        <div class=\"max-w-3xl mx-auto\" data-kid=\"1-6-1\" data-name=\"cta content wrapper\">\n            <div class=\"ngi-overline text-[var(--color-gold)] mb-6 flex items-center justify-center\" data-kid=\"1-6-1-1\" data-name=\"cta overline with accent rule\">\n                <span class=\"ngi-rule\" data-kid=\"1-6-1-1-1\" data-name=\"horizontal accent rule\">\n                </span>\n                Work With Us\n            </div>\n            <h2 class=\"font-serif text-5xl md:text-8xl font-light tracking-tighter leading-[0.95] mb-12\" data-kid=\"1-6-1-2\" data-name=\"cta headline text\">\n                Begin a quiet\n                <em class=\"italic text-[var(--color-ink-secondary)]\" data-kid=\"1-6-1-2-1\" data-name=\"italic emphasis text\">\n                    conversation.\n                </em>\n            </h2>\n            <a class=\"inline-flex items-center bg-[var(--color-dark-primary)] text-white px-12 py-6 text-[11px] tracking-[0.22em] uppercase hover:bg-[var(--color-gold)] transition-all duration-500 group\" data-kid=\"1-6-1-3\" data-name=\"book consultation button\" href=\"/consultation\">\n                Book a Consultation\n                <svg class=\"ml-3 w-4 h-4 transition-transform group-hover:translate-x-1 group-hover:-translate-y-1\" data-kid=\"1-6-1-3-1\" data-name=\"arrow icon\" fill=\"none\" stroke=\"currentColor\" viewbox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n                    <path d=\"M14 5l7 7m0 0l-7 7m7-7H3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\">\n                    </path>\n                </svg>\n            </a>\n        </div>\n    </section>\n</div>\n<style>\n    @keyframes fadeIn {\n    from { opacity: 0; transform: translateY(32px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n</style>\n",
